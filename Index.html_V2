<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "surface-bright": "#393939",
              "tertiary-fixed-dim": "#FF9F00",
              "surface-container-low": "#1c1b1b",
              "surface-dim": "#131313",
              "surface": "#131313",
              "surface-container-lowest": "#0e0e0e",
              "on-surface-variant": "#c2c6d2",
              "on-primary": "#0a0a0a",
              "error": "#ffb4ab",
              "surface-variant": "#353534",
              "surface-container": "#201f1f",
              "outline-variant": "#424750",
              "surface-container-highest": "#353534",
              "primary": "#FF9F00",
              "on-background": "#e5e2e1",
              "on-surface": "#e5e2e1",
              "background": "#131313",
              "surface-container-high": "#2a2a2a"
            },
            fontFamily: {
              sans: ['"Hanken Grotesk"', 'system-ui', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      * { box-sizing: border-box; }

      :root {
        --primary-nav: #090a0f;  /* Deep black-blue */
        --accent: #FF9F00;       /* NHL Orange */
        --bg: #0f1115;           /* Dark sports background */
        --surface: #1a1d24;      /* Elevated card surface */
        --surface-hover: #232730;
        --text: #f8fafc;         /* Crisp white text */
        --text-muted: #94a3b8;   /* Slate gray */
        --border: #2e3340;
        --sidebar-hover: #1a1d24;
      }

      body.app-shell { font-family: 'Hanken Grotesk', system-ui, sans-serif; margin: 0; padding: 0; background-color: var(--bg); color: var(--text); display: flex; height: 100vh; overflow: hidden; }

      .sidebar { width: 260px; background-color: var(--primary-nav); color: white; display: flex; flex-direction: column; z-index: 100; transition: transform 0.3s ease; flex-shrink: 0; overflow-y: auto; overflow-x: hidden; border-right: 1px solid var(--border); }
      .logo-container { padding: 25px 20px; text-align: center; border-bottom: 1px solid var(--border); margin-bottom: 10px; background: radial-gradient(circle at top, #1a1d24 0%, transparent 100%); }
      .logo-container img { max-width: 100%; height: auto; border-radius: 8px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5)); }

      .nav-item { padding: 16px 20px; color: var(--text-muted); text-decoration: none; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; display: flex; align-items: center; border-left: 4px solid transparent;}
      .nav-item:hover, .nav-item.active { background-color: var(--sidebar-hover); color: white; border-left-color: var(--accent); }
      .nav-item.highlight { border-left-color: #ef4444; color: #ef4444; font-weight: 800; letter-spacing: 0.5px; }

      .main-wrapper { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
      .topbar-mobile { display: none; background-color: var(--primary-nav); color: white; padding: 15px 20px; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); }
      .mobile-menu-btn { background: none; border: none; color: white; font-size: 1.8rem; cursor: pointer; padding: 0; }

      .main-content { flex: 1; padding: 30px; overflow-y: auto; overflow-x: hidden; display: flex; flex-direction: column; position: relative;}
      #app-canvas { flex: 1; background: transparent; border-radius: 12px; overflow-y: auto; overflow-x: hidden;}

      .color-dot { display: inline-block; width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--surface); vertical-align: middle; margin-right: 8px; box-shadow: 0 0 8px rgba(255,255,255,0.1); }
      .badge { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; background: var(--border); color: var(--text); text-transform: uppercase; letter-spacing: 0.5px; }

      .btn { background: var(--accent); color: #0a0a0a; border: none; padding: 12px 20px; border-radius: 6px; cursor: pointer; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; transition: all 0.2s ease; font-size: 0.9rem; box-shadow: 0 4px 12px rgba(255, 159, 0, 0.25); }
      .btn:hover { background: #ffaa22; transform: translateY(-2px); box-shadow: 0 6px 16px rgba(255, 159, 0, 0.4); }

      /* ========================================================================== */
      /* GLOBAL PREMIUM OVERRIDES VOOR ALLE (BESTAANDE) VIEWS                       */
      /* Dit herschrijft automatisch je witte achtergronden naar NHL Dark Mode      */
      /* ========================================================================== */
      .form-container, .profile-section, .stats-header, .line-section, .boxscore-section, div[style*="background: white"], div[style*="background:white"] {
          background: var(--surface) !important; border: 1px solid var(--border) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.2) !important; color: var(--text) !important; border-radius: 12px !important;
      }
      h3, .section-title, .line-title { color: white !important; border-bottom-color: var(--border) !important; }

      table, .app-table { background: var(--surface) !important; color: var(--text) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.2) !important; border-radius: 12px !important; border-collapse: separate !important; border-spacing: 0 !important; border: 1px solid var(--border) !important; }
      th { background-color: var(--primary-nav) !important; color: var(--text-muted) !important; border-bottom: 2px solid var(--border) !important; font-size: 0.75rem !important; text-transform: uppercase !important; letter-spacing: 1px !important; padding: 16px 15px !important; }
      td { border-bottom: 1px solid var(--border) !important; color: var(--text) !important; padding: 16px 15px !important; }
      tr:hover td { background-color: var(--surface-hover) !important; cursor: default; }

      .form-group label, .input-group label, .pos-item label { color: var(--text-muted) !important; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.75rem !important; }
      input, select, textarea { background-color: var(--bg) !important; color: white !important; border: 1px solid var(--border) !important; border-radius: 6px !important; padding: 12px !important; font-size: 0.95rem !important; transition: border-color 0.2s ease !important; }
      input:focus, select:focus { border-color: var(--accent) !important; box-shadow: 0 0 0 3px rgba(255,159,0,0.15) !important; outline: none !important; }

      .status-actief { background: rgba(34, 197, 94, 0.15) !important; color: #4ade80 !important; border: 1px solid rgba(74, 222, 128, 0.2) !important; padding: 4px 10px !important; border-radius: 6px !important; text-transform: uppercase; font-size: 0.7rem !important; letter-spacing: 0.5px; }
      .status-gepland { background: rgba(234, 179, 8, 0.15) !important; color: #facc15 !important; border: 1px solid rgba(250, 204, 21, 0.2) !important; padding: 4px 10px !important; border-radius: 6px !important; text-transform: uppercase; font-size: 0.7rem !important; letter-spacing: 0.5px; }

      @media(max-width: 768px) {
        .sidebar { position: fixed; top: 0; left: 0; height: 100%; transform: translateX(-100%); box-shadow: 10px 0 30px rgba(0,0,0,0.8); z-index: 999; }
        .sidebar.open { transform: translateX(0); }
        .topbar-mobile { display: flex; }
        .main-content { padding: 15px; }
      }
      .sidebar::-webkit-scrollbar, .main-content::-webkit-scrollbar, #app-canvas::-webkit-scrollbar { display: none; }
      .sidebar, .main-content, #app-canvas { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>
  <body class="app-shell">

    <div id="startup-modal" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; display:none; align-items:center; justify-content:center; backdrop-filter: blur(4px);">
      <div style="background:var(--surface); padding:30px; border-radius:12px; max-width:400px; text-align:center; border: 1px solid var(--outline-variant); box-shadow: 0 10px 25px rgba(0,0,0,0.5);">
        <h2 style="color:var(--accent); margin-top:0;">Welkom bij de App!</h2>
        <p style="color:#d1d5db; font-size:0.95rem; line-height:1.5;">Voordat je het ijs betreedt, vragen we je akkoord te gaan met de officiële competitiereglementen en ons privacybeleid.</p>
        <button id="btn-accept-terms" class="btn" style="background:var(--accent); color:#131313; width:100%; margin-top:20px; font-size:1.1rem;">Ik ga akkoord</button>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        if(!sessionStorage.getItem('termsAccepted')) {
          document.getElementById('startup-modal').style.display = 'flex';
        }
        document.getElementById('btn-accept-terms').addEventListener('click', () => {
          sessionStorage.setItem('termsAccepted', 'true');
          document.getElementById('startup-modal').style.display = 'none';
        });
      });
    </script>

    <div class="sidebar" id="sidebar">
      <div class="logo-container">
        <img src="https://cdn.shopify.com/s/files/1/1038/7203/7203/files/blackout_league_manager_logo.png?v=1783250434" alt="Club Logo">
      </div>

      <div style="padding: 0 20px 15px 20px;">
        <select id="roleSwitcher" onchange="wisselRol(this.value)" style="width: 100%; padding: 8px; background: var(--surface); color: white; border: 1px solid var(--border); border-radius: 4px; font-size: 0.9rem; cursor: pointer;">
          <option value="gast">👁️ Rol: Gast / Bezoeker</option>
          <option value="speler">👤 Rol: Speler</option>
          <option value="beheerder">🛡️ Rol: Beheerder</option>
        </select>
      </div>

      <!-- Algemene weergave voor IEDEREEN -->
      <a class="nav-item active" data-role="all" onclick="laadView('Dashboard', this); sluitMobielMenu();">Dashboard</a>
      <a class="nav-item" data-role="all" onclick="laadView('Wedstrijden', this); sluitMobielMenu();">Kalender</a>
      <a class="nav-item" data-role="all" onclick="laadView('Standen', this); sluitMobielMenu();">Standen</a>
      <a class="nav-item" data-role="all" onclick="laadView('Statistieken', this); sluitMobielMenu();">Speler Stats</a>

      <!-- Specifieke weergaves -->
      <a class="nav-item highlight" data-role="gast" onclick="laadView('Register', this); sluitMobielMenu();">📝 Registreren</a>
      <a class="nav-item" data-role="speler" onclick="laadView('Aanvragen', this); sluitMobielMenu();">Team Joinen (Aanvraag)</a>

      <div id="beheerder-menu-header" style="padding: 15px 20px 5px 20px; font-size: 0.75rem; color: #737373; text-transform: uppercase; font-weight: bold; letter-spacing: 1px;">Beheer & Live</div>
      <a class="nav-item highlight" data-role="beheerder" onclick="laadView('Live', this); sluitMobielMenu();">🔴 Live Tracker</a>
      <a class="nav-item" data-role="beheerder" onclick="laadView('Lijnen', this); sluitMobielMenu();">Line-ups</a>
      <a class="nav-item" data-role="beheerder" onclick="laadView('Competities', this); sluitMobielMenu();">Competities</a>
      <a class="nav-item" data-role="beheerder" onclick="laadView('Teams', this); sluitMobielMenu();">Teams</a>
      <a class="nav-item" data-role="beheerder" onclick="laadView('Rosters', this); sluitMobielMenu();">Rosters</a>
      <a class="nav-item" data-role="beheerder" onclick="laadView('Users', this); sluitMobielMenu();">Gebruikers</a>
    </div>

    <div class="main-wrapper">
      <div class="topbar-mobile">
        <div style="display: flex; align-items: center; gap: 10px;">
          <img src="https://cdn.shopify.com/s/files/1/1038/7203/7203/files/Blackout_White_on_Black.png?v=1769768413" alt="Club Logo" style="height: 30px; border-radius: 4px;">
          <span style="font-weight: 800; letter-spacing: 1px; color: var(--accent); font-size: 1.1rem;">Multi-League Manager</span>
        </div>
        <button class="mobile-menu-btn" onclick="toggleMobielMenu()">☰</button>
      </div>

      <div class="main-content">
        <div id="loader" style="display:none; color: #737373; font-weight: bold;">Data laden... ⏳</div>
        <div id="app-canvas"><p style="padding:20px;">Welkom! Selecteer een optie in het menu.</p></div>

        <!-- ============================================== -->
        <!-- BLOK 2: DETAIL PAGINA'S (SPELER & TEAM)        -->
        <!-- ============================================== -->

        <!-- PREMIUM SPELER DETAIL PAGINA -->
        <div id="view-player-detail" style="display:none; padding-bottom: 40px; width: 100%;">
           <button onclick="sluitProfiel()" class="btn" style="background:var(--surface-hover); color:white; border:1px solid var(--border); margin-bottom:20px; display:inline-flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined">arrow_back</span> Terug
           </button>

           <div style="background:var(--surface); border-radius:16px; overflow:hidden; border:1px solid var(--border); box-shadow: 0 10px 30px rgba(0,0,0,0.2); margin-bottom:25px; position:relative;">
              <div style="height: 120px; background: linear-gradient(135deg, var(--primary-nav) 0%, #1e3a8a 100%); border-bottom: 2px solid var(--accent);"></div>
              <div style="padding: 0 30px 30px 30px; display:flex; gap:25px; align-items:flex-end; margin-top: -60px;">
                 <img id="detail-player-img" src="" alt="Speler Foto" style="width:140px; height:140px; border-radius:50%; border:4px solid var(--surface); box-shadow: 0 8px 20px rgba(0,0,0,0.5); object-fit:cover; background:var(--bg); position:relative; z-index:2;">
                 <div style="padding-bottom: 10px; flex:1;">
                    <h2 id="detail-player-name" style="margin:0; color:white; font-size:2.5rem; font-weight:900; letter-spacing: 0.5px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">Speler Naam</h2>
                    <p id="detail-player-role" style="margin:5px 0 0 0; color:var(--accent); font-weight:800; font-size:1.1rem; text-transform:uppercase; letter-spacing:2px;">Rol / Positie</p>
                 </div>
              </div>
           </div>

           <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap:25px;">

              <!-- Realtime Statistieken Card -->
              <div style="background:var(--surface); padding:25px; border-radius:16px; border:1px solid var(--border); box-shadow: 0 8px 25px rgba(0,0,0,0.15);">
                 <h3 style="color:white; border-bottom:2px solid var(--border); padding-bottom:12px; margin-top:0; font-size:1.1rem; text-transform:uppercase; font-weight:900; letter-spacing:1px; display:flex; align-items:center; gap:8px;">
                    <span class="material-symbols-outlined" style="color:var(--accent);">query_stats</span> Seizoensstatistieken
                 </h3>
                 <div id="detail-player-stats-loader" style="text-align:center; padding:30px 0; color:var(--text-muted); font-style:italic;">Statistieken inladen... ⏳</div>
                 <div id="detail-player-stats-container" style="display:none; grid-template-columns: repeat(2, 1fr); gap:15px; margin-top:15px;">
                    <div style="background:var(--bg); padding:15px; border-radius:8px; border:1px solid var(--border); text-align:center;">
                       <div style="font-size:0.8rem; color:var(--text-muted); font-weight:bold; text-transform:uppercase; letter-spacing:1px;">Goals</div>
                       <div id="dp-stat-g" style="font-size:2rem; font-weight:900; color:white;">0</div>
                    </div>
                    <div style="background:var(--bg); padding:15px; border-radius:8px; border:1px solid var(--border); text-align:center;">
                       <div style="font-size:0.8rem; color:var(--text-muted); font-weight:bold; text-transform:uppercase; letter-spacing:1px;">Assists</div>
                       <div id="dp-stat-a" style="font-size:2rem; font-weight:900; color:white;">0</div>
                    </div>
                    <div style="background:var(--accent); padding:15px; border-radius:8px; border:1px solid rgba(255,255,255,0.2); text-align:center; box-shadow: 0 4px 15px rgba(255,159,0,0.3);">
                       <div style="font-size:0.8rem; color:#0a0a0a; font-weight:900; text-transform:uppercase; letter-spacing:1px;">Points</div>
                       <div id="dp-stat-pts" style="font-size:2rem; font-weight:900; color:#0a0a0a;">0</div>
                    </div>
                    <div style="background:var(--bg); padding:15px; border-radius:8px; border:1px solid var(--border); text-align:center;">
                       <div style="font-size:0.8rem; color:var(--text-muted); font-weight:bold; text-transform:uppercase; letter-spacing:1px;">PIM</div>
                       <div id="dp-stat-pim" style="font-size:2rem; font-weight:900; color:#ef4444;">0</div>
                    </div>
                 </div>
                 <div id="detail-goalie-stats-container" style="display:none; grid-template-columns: repeat(3, 1fr); gap:10px; margin-top:15px;">
                    <div style="background:var(--bg); padding:15px 5px; border-radius:8px; border:1px solid var(--border); text-align:center;">
                       <div style="font-size:0.7rem; color:var(--text-muted); font-weight:bold; text-transform:uppercase; letter-spacing:1px;">Saves</div>
                       <div id="dp-stat-sv" style="font-size:1.6rem; font-weight:900; color:white;">0</div>
                    </div>
                    <div style="background:var(--bg); padding:15px 5px; border-radius:8px; border:1px solid var(--border); text-align:center;">
                       <div style="font-size:0.7rem; color:var(--text-muted); font-weight:bold; text-transform:uppercase; letter-spacing:1px;">GA</div>
                       <div id="dp-stat-ga" style="font-size:1.6rem; font-weight:900; color:white;">0</div>
                    </div>
                    <div style="background:var(--accent); padding:15px 5px; border-radius:8px; border:1px solid rgba(255,255,255,0.2); text-align:center;">
                       <div style="font-size:0.7rem; color:#0a0a0a; font-weight:900; text-transform:uppercase; letter-spacing:1px;">SV%</div>
                       <div id="dp-stat-svp" style="font-size:1.6rem; font-weight:900; color:#0a0a0a;">0</div>
                    </div>
                 </div>
              </div>

              <!-- Stick Specificaties Card -->
              <div style="background:var(--surface); padding:25px; border-radius:16px; border:1px solid var(--border); box-shadow: 0 8px 25px rgba(0,0,0,0.15);">
                 <h3 style="color:white; border-bottom:2px solid var(--border); padding-bottom:12px; margin-top:0; font-size:1.1rem; text-transform:uppercase; font-weight:900; letter-spacing:1px; display:flex; align-items:center; gap:8px;">
                    <span class="material-symbols-outlined" style="color:var(--text-muted);">sports_hockey</span> Stick Specificaties
                 </h3>
                 <table style="width:100%; text-align:left; border-collapse: collapse; margin-top:15px; border:none; box-shadow:none;">
                    <tr><th style="padding:12px 0; color:var(--text-muted); border-bottom:1px solid var(--border); background:transparent; font-size:0.85rem;">Merk</th><td id="detail-stick-brand" style="border-bottom:1px solid var(--border); font-weight:bold; color:white; padding:12px 0;">-</td></tr>
                    <tr><th style="padding:12px 0; color:var(--text-muted); border-bottom:1px solid var(--border); background:transparent; font-size:0.85rem;">Model</th><td id="detail-stick-model" style="border-bottom:1px solid var(--border); font-weight:bold; color:white; padding:12px 0;">-</td></tr>
                    <tr><th style="padding:12px 0; color:var(--text-muted); border-bottom:1px solid var(--border); background:transparent; font-size:0.85rem;">Curve</th><td id="detail-stick-curve" style="border-bottom:1px solid var(--border); font-weight:bold; color:white; padding:12px 0;">-</td></tr>
                    <tr><th style="padding:12px 0; color:var(--text-muted); border-bottom:none; background:transparent; font-size:0.85rem;">Flex</th><td id="detail-stick-flex" style="font-weight:bold; color:var(--accent); border-bottom:none; padding:12px 0; font-size:1.1rem;">-</td></tr>
                 </table>
              </div>

           </div>
        </div>

        <!-- PREMIUM TEAM DETAIL PAGINA -->
        <div id="view-team-detail" style="display:none; padding-bottom: 40px; width: 100%;">
           <button onclick="sluitProfiel()" class="btn" style="background:var(--surface-hover); color:white; border:1px solid var(--border); margin-bottom:20px; display:inline-flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined">arrow_back</span> Terug naar lijst
           </button>

           <div id="dt-header-bg" style="background:linear-gradient(135deg, #1e3a8a 0%, var(--primary-nav) 100%); border-radius:16px; padding:40px 30px; border:1px solid var(--border); margin-bottom:25px; text-align:center; box-shadow: 0 10px 30px rgba(0,0,0,0.3); position:relative; overflow:hidden;">
              <span class="material-symbols-outlined" style="position:absolute; font-size:15rem; color:white; opacity:0.05; right:-30px; top:-30px; transform:rotate(-15deg);">shield</span>
              <h2 id="detail-team-name" style="margin:0; color:white; font-size:3rem; font-weight:900; text-transform:uppercase; letter-spacing:1px; position:relative; z-index:2; text-shadow: 0 4px 10px rgba(0,0,0,0.5);">Team Naam</h2>
              <p style="color:var(--text-muted); margin-top:10px; font-weight:900; letter-spacing:3px; position:relative; z-index:2; text-transform:uppercase;">Officiële Selectie</p>
           </div>

           <div style="background:var(--surface); padding:25px; border-radius:16px; border:1px solid var(--border); box-shadow: 0 8px 25px rgba(0,0,0,0.15);">
               <h3 style="color:white; border-bottom:2px solid var(--border); padding-bottom:12px; margin-top:0; font-size:1.1rem; text-transform:uppercase; font-weight:900; letter-spacing:1px; display:flex; align-items:center; gap:8px;">
                  <span class="material-symbols-outlined" style="color:var(--accent);">groups</span> Roster (Actieve Spelers)
               </h3>
               <div id="detail-team-roster">
                  <p style="color:var(--text-muted); font-style:italic; text-align:center; padding: 30px 0;">De selectie van dit team wordt hier ingeladen... ⏳</p>
               </div>
           </div>
        </div>
        <!-- EINDE BLOK 2 -->
      </div>
    </div>

<script>
      // ==========================================
      // HELPER: Anti-crash String Escaper
      // ==========================================
      function escapeJS(str) {
        if (str === null || str === undefined) return '';
        return String(str)
          .replace(/\\/g, '\\\\')
          .replace(/'/g, "\\'")
          .replace(/"/g, '&quot;')
          .replace(/`/g, '\\`')
          .replace(/\n/g, '\\n')
          .replace(/\r/g, '\\r');
      }

      let globaalTeamsData = [];
      window.liveMatchInterval = null;

      function laadView(viewNaam, menuElement) {
        if(window.liveMatchInterval) {
           clearInterval(window.liveMatchInterval);
           window.liveMatchInterval = null;
        }

        document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
        if(menuElement) menuElement.classList.add('active');

        const canvas = document.getElementById('app-canvas');
        const loader = document.getElementById('loader');

        sluitProfiel();
        if(canvas) canvas.innerHTML = '';
        if(loader) loader.style.display = 'block';

        google.script.run
          .withSuccessHandler(function(html) {
            if(loader) loader.style.display = 'none';
            if(canvas) canvas.innerHTML = html;

            if (viewNaam === 'Dashboard') { initDashboardScherm(); }
            else if (viewNaam === 'Users') { haalGebruikersOp(); }
            else if (viewNaam === 'Competities') { haalCompetitiesOp(); }
            else if (viewNaam === 'Teams') { initTeamsScherm(); }
            else if (viewNaam === 'Rosters') { initRostersScherm(); }
            else if (viewNaam === 'Wedstrijden') { initWedstrijdenScherm(); }
            else if (viewNaam === 'Live') { initAdvancedLiveTracker(); }
            else if (viewNaam === 'Standen') { initStandenScherm(); }
            else if (viewNaam === 'Aanvragen') { initAanvragenScherm(); }
            else if (viewNaam === 'Statistieken') { initStatistiekenScherm(); }
            else if (viewNaam === 'Lijnen') { initLijnenScherm(); }
            // Register view heeft geen init logica nodig
          })
          .withFailureHandler(function(error) {
            if(loader) loader.style.display = 'none';
            if(canvas) canvas.innerHTML = '<p style="color:red">Fout: ' + error.message + '</p>';
          }).getViewHTML(viewNaam);
      }

      function initAdvancedLiveTracker() {
        const AppState = {
            matchId: null, clockSeconds: 1200, isRunning: false, clockInterval: null,
            homeTeam: 'THUIS', awayTeam: 'UIT', homeColor: '#3b82f6', awayColor: '#ef4444',
            homeId: null, awayId: null, dbMatchId: null,
            stats: { HOME: { score: 0, shots: 0, saves: 0, faceoffs: 0, penalties: 0 }, AWAY: { score: 0, shots: 0, saves: 0, faceoffs: 0, penalties: 0 } },
            ui: { selectedPenaltyTeam: 'HOME', selectedGoalTeam: 'HOME' }, rosters: { HOME: [], AWAY: [] }
        };

        const DOM = {
            clock: { main: document.getElementById('match-clock'), modal: document.getElementById('modal-clock-display'), btnPlus: document.getElementById('btn-plus-1s'), btnMinus: document.getElementById('btn-minus-1s'), btnToggle: document.getElementById('btn-clock-toggle') },
            scoreboard: { homeScore: document.getElementById('score-home'), awayScore: document.getElementById('score-away'), homeShots: document.getElementById('shots-home'), awayShots: document.getElementById('shots-away'), headerTitle: document.getElementById('match-header-title'), homeScoreIcon: document.getElementById('home-score-icon'), awayScoreIcon: document.getElementById('away-score-icon'), headerAwayIcon: document.getElementById('header-away-icon'), period: document.getElementById('display-period') },
            rink: { container: document.getElementById('interactive-rink'), areaLii: document.getElementById('rink-lii'), areaTor: document.getElementById('rink-tor') },
            navigation: { controls: document.querySelectorAll('.control-btn'), tabs: document.querySelectorAll('.tab-btn'), viewsContainer: document.getElementById('views-container'), mainViews: [ document.getElementById('view-pre-game'), document.getElementById('view-match'), document.getElementById('view-post-game') ], headerTabs: document.getElementById('header-tabs') },
            modal: { container: document.getElementById('whistle-modal'), btnWhistle: document.getElementById('btn-whistle'), btnClose: document.getElementById('close-modal'), btnResume: document.getElementById('resume-play'), actionBtns: document.querySelectorAll('.modal-action-btn') },
            feed: { list: document.getElementById('play-by-play-list') },
            settings: { gasImport: document.getElementById('gas-match-import'), homeTeam: document.getElementById('home-team'), awayTeam: document.getElementById('away-team'), inputMinutes: document.getElementById('settings-minutes'), inputPeriods: document.getElementById('settings-periods'), btnSaveStart: document.getElementById('btn-save-start'), selectMatch: document.getElementById('live-match-select') },
            roster: { homeList: document.getElementById('home-roster-list'), awayList: document.getElementById('away-roster-list') },
            stats: { shotsH: document.getElementById('stat-shots-home'), shotsA: document.getElementById('stat-shots-away'), barShotsH: document.getElementById('bar-shots-home'), barShotsA: document.getElementById('bar-shots-away'), foH: document.getElementById('stat-fo-home'), foA: document.getElementById('stat-fo-away'), barFoH: document.getElementById('bar-fo-home'), barFoA: document.getElementById('bar-fo-away'), goalsH: document.getElementById('stat-goals-home'), goalsA: document.getElementById('stat-goals-away'), penH: document.getElementById('stat-pen-home'), penA: document.getElementById('stat-pen-away') },
            postgame: { btnFinalize: document.getElementById('btn-postgame-finalize'), scorer: document.getElementById('final-scorer'), ref: document.getElementById('final-ref') }
        };

        if(DOM.settings.gasImport) {
          google.script.run.withSuccessHandler(function(res) {
            DOM.settings.gasImport.innerHTML = '<option value="">-- Vul Pre-Game settings in via DB --</option>';
            for(let i=1; i<res.length; i++) DOM.settings.gasImport.innerHTML += '<option value="' + res[i][0] + '" data-thuis="' + res[i][4] + '" data-uit="' + res[i][5] + '">' + res[i][2] + ' | Thuis vs Uit ID: ' + res[i][0].substring(0,4) + '</option>';
          }).doAction('Wedstrijden', 'haalRuweWedstrijdenOp', null);

          google.script.run.withSuccessHandler(function(res) { if(res.status==='success') globaalTeamsData = res.data; }).doAction('Teams', 'haalTeamsOp', null);

          DOM.settings.gasImport.addEventListener('change', (e) => {
            const opt = e.target.options[e.target.selectedIndex];
            AppState.dbMatchId = opt.value;
            if(!AppState.dbMatchId) return;
            const tId = opt.getAttribute('data-thuis'); const uId = opt.getAttribute('data-uit');

            globaalTeamsData.forEach(t => {
              if(t[0] === tId) DOM.settings.homeTeam.value = t[2] || t[1].substring(0,3).toUpperCase();
              if(t[0] === uId) DOM.settings.awayTeam.value = t[2] || t[1].substring(0,3).toUpperCase();
            });

            if(DOM.roster.homeList) DOM.roster.homeList.innerHTML = 'Laden...';
            if(DOM.roster.awayList) DOM.roster.awayList.innerHTML = 'Laden...';

            google.script.run.withSuccessHandler(rData => {
              AppState.rosters.HOME = []; if(rData.status === 'success') { for(let i=1; i<rData.data.length; i++) AppState.rosters.HOME.push({number: rData.data[i][2], name: rData.data[i][0]}); if(DOM.roster.homeList) populateRosterList(DOM.roster.homeList, AppState.rosters.HOME); }
            }).doAction('Rosters', 'haalRosterOp', tId);
            google.script.run.withSuccessHandler(rData => {
              AppState.rosters.AWAY = []; if(rData.status === 'success') { for(let i=1; i<rData.data.length; i++) AppState.rosters.AWAY.push({number: rData.data[i][2], name: rData.data[i][0]}); if(DOM.roster.awayList) populateRosterList(DOM.roster.awayList, AppState.rosters.AWAY); }
            }).doAction('Rosters', 'haalRosterOp', uId);
          });
        }

        function createPlayerRow(number = '', name = '') {
            const row = document.createElement('div'); row.className = 'flex gap-2 items-center roster-row';
            row.innerHTML = '<input type="text" placeholder="#" class="w-16 bg-surface border border-outline-variant text-on-surface rounded-md py-1 px-2 text-center text-body-sm roster-number" value="' + number + '"><input type="text" placeholder="Player Name" class="flex-1 bg-surface border border-outline-variant text-on-surface rounded-md py-1 px-2 text-body-sm roster-name" value="' + name + '"><button class="text-on-surface-variant hover:text-error transition-colors p-1 btn-remove-player"><span class="material-symbols-outlined" style="font-size: 18px;">delete</span></button>';
            row.querySelector('.btn-remove-player').addEventListener('click', () => { row.remove(); });
            return row;
        }

        function populateRosterList(listElement, players) {
            if(!listElement) return; listElement.innerHTML = '';
            players.forEach(p => listElement.appendChild(createPlayerRow(p.number, p.name)));
        }

        DOM.navigation.controls.forEach(btn => {
            btn.addEventListener('click', () => {
                DOM.navigation.controls.forEach(b => b.classList.remove('active')); btn.classList.add('active');
                DOM.navigation.mainViews.forEach(v => { if(v) v.classList.add('hidden'); });
                const targetView = document.getElementById(btn.getAttribute('data-target'));
                if(targetView) targetView.classList.remove('hidden');
                if (btn.getAttribute('data-target') === 'view-match') { if(DOM.navigation.headerTabs) DOM.navigation.headerTabs.classList.remove('hidden'); }
                else { if(DOM.navigation.headerTabs) DOM.navigation.headerTabs.classList.add('hidden'); stopClock(); }
            });
        });

        DOM.navigation.tabs = document.querySelectorAll('.tab-btn');
        DOM.navigation.tabs.forEach(btn => {
          btn.addEventListener('click', () => {
            DOM.navigation.tabs.forEach(b => b.classList.remove('text-tertiary-fixed-dim', 'border-b-2', 'active-tab'));
            btn.classList.add('text-tertiary-fixed-dim', 'border-b-2', 'active-tab');
            ['view-play-by-play', 'view-summary', 'view-stats', 'view-lines'].forEach(id => {
              const el = document.getElementById(id); if(el) el.classList.add('hidden');
            });
            const targetEl = document.getElementById(btn.getAttribute('data-target'));
            if(targetEl) targetEl.classList.remove('hidden');
          });
        });

        google.script.run.withSuccessHandler(res => { if(res.status==='success') globaalTeamsData = res.data; }).doAction('Teams', 'haalTeamsOp', null);
        google.script.run.withSuccessHandler(ruweWedstrijden => {
           if (DOM.settings.selectMatch) {
             DOM.settings.selectMatch.innerHTML = '<option value="">-- Kies een wedstrijd --</option>';
             for(let i=1; i<ruweWedstrijden.length; i++) DOM.settings.selectMatch.innerHTML += '<option value="' + ruweWedstrijden[i][0] + '" data-thuis="' + ruweWedstrijden[i][4] + '" data-uit="' + ruweWedstrijden[i][5] + '">' + ruweWedstrijden[i][2] + ' | Thuis vs Uit ID: ' + ruweWedstrijden[i][0].substring(0,4) + '</option>';
           }
        }).doAction('Wedstrijden', 'haalRuweWedstrijdenOp', null);

        if (DOM.settings.btnSaveStart) {
          DOM.settings.btnSaveStart.addEventListener('click', () => {
            const select = DOM.settings.selectMatch || document.getElementById('live-match-select');
            if(select && !select.value) return alert("Selecteer een wedstrijd.");
            if(select) {
              const opt = select.options[select.selectedIndex];
              AppState.dbMatchId = opt.value; AppState.homeId = opt.getAttribute('data-thuis'); AppState.awayId = opt.getAttribute('data-uit');
            }

            globaalTeamsData.forEach(t => {
              if(t[0] === AppState.homeId) { AppState.homeTeam = t[2]||t[1].substring(0,3).toUpperCase(); AppState.homeColor = t[3]||'#e67e22'; document.getElementById('btn-goal-home').innerText=AppState.homeTeam; document.getElementById('btn-faceoff-home').innerText="Win "+AppState.homeTeam; document.getElementById('btn-penalty-home').innerText=AppState.homeTeam; if(document.getElementById('stat-hdr-home')) document.getElementById('stat-hdr-home').innerText=AppState.homeTeam; if(document.getElementById('sum-name-home')) document.getElementById('sum-name-home').innerText=AppState.homeTeam;}
              if(t[0] === AppState.awayId) { AppState.awayTeam = t[2]||t[1].substring(0,3).toUpperCase(); AppState.awayColor = t[3]||'#004b8d'; document.getElementById('btn-goal-away').innerText=AppState.awayTeam; document.getElementById('btn-faceoff-away').innerText="Win "+AppState.awayTeam; document.getElementById('btn-penalty-away').innerText=AppState.awayTeam; if(document.getElementById('stat-hdr-away')) document.getElementById('stat-hdr-away').innerText=AppState.awayTeam; if(document.getElementById('sum-name-away')) document.getElementById('sum-name-away').innerText=AppState.awayTeam;}
            });

            document.documentElement.style.setProperty('--color-home', AppState.homeColor); document.documentElement.style.setProperty('--color-away', AppState.awayColor);
            DOM.scoreboard.homeIcon.innerText = AppState.homeTeam.substring(0,1); DOM.scoreboard.awayIcon.innerText = AppState.awayTeam.substring(0,1);
            DOM.scoreboard.headerTitle.innerText = AppState.homeTeam + ' vs ' + AppState.awayTeam;

            if(DOM.settings.inputMinutes) AppState.clockSeconds = parseInt(DOM.settings.inputMinutes.value) * 60;
            updateClockDisplay();

            const hdrHome = document.getElementById('lines-hdr-home'); if(hdrHome) hdrHome.innerText = AppState.homeTeam;
            const hdrAway = document.getElementById('lines-hdr-away'); if(hdrAway) hdrAway.innerText = AppState.awayTeam;

            function renderLijnen(teamId, containerId) {
              google.script.run.withSuccessHandler(lijnen => {
                 const container = document.getElementById(containerId);
                 if(!container) return;
                 if(!lijnen) { container.innerHTML = '<p class="opacity-50 italic">Geen formaties opgeslagen.</p>'; return; }

                 let html = '';
                 const blokken = [{id: 'l1', naam: '1e Lijn'}, {id: 'l2', naam: '2e Lijn'}, {id: 'pp', naam: 'Powerplay'}];

                 blokken.forEach(b => {
                    html += '<div class="mb-3"><strong class="border-b border-outline-variant block mb-1 text-on-surface-variant">' + b.naam + '</strong>';
                    for(const [key, speler] of Object.entries(lijnen)) {
                       if(key.startsWith(b.id + '-')) {
                          let pos = key.split('-')[1].toUpperCase();
                          html += '<div class="flex justify-between py-1 border-b border-surface-variant border-opacity-50"><span>' + pos + '</span><span class="font-bold">' + speler + '</span></div>';
                       }
                    }
                    html += '</div>';
                 });
                 container.innerHTML = html;
              }).doAction('Lijnen', 'haalLijnenOp', teamId);
            }
            renderLijnen(AppState.homeId, 'lines-content-home');
            renderLijnen(AppState.awayId, 'lines-content-away');

            const activeGoalieH = document.getElementById('active-goalie-home');
            const activeGoalieA = document.getElementById('active-goalie-away');

            google.script.run.withSuccessHandler(rData => {
              if(rData.status === 'success') {
                let html = '<option value="">Selecteer speler...</option>';
                let goalieHtml = '<option value="Empty Net">-- Empty Net --</option>';
                for(let i=1; i<rData.data.length; i++) {
                   const spelerNaam = '#' + rData.data[i][2] + ' ' + rData.data[i][0];
                   html += '<option value="' + spelerNaam + '">' + spelerNaam + '</option>';
                   goalieHtml += '<option value="' + spelerNaam + '">' + spelerNaam + '</option>';
                }
                document.querySelectorAll('#view-match .goal-player-select[data-team="HOME"], #view-match .penalty-player-select[data-team="HOME"]').forEach(sel => sel.innerHTML = html);
                if(activeGoalieH) {
                   activeGoalieH.innerHTML = goalieHtml;
                   google.script.run.withSuccessHandler(lijnen => {
                     if(lijnen) {
                       for(const [key, speler] of Object.entries(lijnen)) {
                         if(key.includes('-g') || key.includes('-G') || speler.toLowerCase().includes('goalie')) {
                           activeGoalieH.value = speler; break;
                         }
                       }
                     }
                   }).doAction('Lijnen', 'haalLijnenOp', AppState.homeId);
                }
              }
            }).doAction('Rosters', 'haalRosterOp', AppState.homeId);

            google.script.run.withSuccessHandler(rData => {
              if(rData.status === 'success') {
                let html = '<option value="">Selecteer speler...</option>';
                let goalieHtml = '<option value="Empty Net">-- Empty Net --</option>';
                for(let i=1; i<rData.data.length; i++) {
                   const spelerNaam = '#' + rData.data[i][2] + ' ' + rData.data[i][0];
                   html += '<option value="' + spelerNaam + '">' + spelerNaam + '</option>';
                   goalieHtml += '<option value="' + spelerNaam + '">' + spelerNaam + '</option>';
                }
                document.querySelectorAll('#view-match .goal-player-select[data-team="AWAY"], #view-match .penalty-player-select[data-team="AWAY"]').forEach(sel => sel.innerHTML = html);
                if(activeGoalieA) {
                   activeGoalieA.innerHTML = goalieHtml;
                   google.script.run.withSuccessHandler(lijnen => {
                     if(lijnen) {
                       for(const [key, speler] of Object.entries(lijnen)) {
                         if(key.includes('-g') || key.includes('-G') || speler.toLowerCase().includes('goalie')) {
                           activeGoalieA.value = speler; break;
                         }
                       }
                     }
                   }).doAction('Lijnen', 'haalLijnenOp', AppState.awayId);
                }
              }
            }).doAction('Rosters', 'haalRosterOp', AppState.awayId);

            DOM.navigation.controls.forEach(b => { if (b.getAttribute('data-target') === 'view-match') b.click(); });
            DOM.navigation.tabs.forEach(b => { if(b.getAttribute('data-target')==='view-play-by-play') b.click(); });
          });
        }

        document.querySelectorAll('.goal-team-btn, .penalty-team-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const teamKey = e.target.getAttribute('data-team');
            const teamId = teamKey === 'HOME' ? AppState.homeId : AppState.awayId;
            const container = e.target.closest('.hidden') || e.target.closest('div[id$="-options"]');
            if (container) {
              const selects = container.querySelectorAll('select.goal-player-select, select.penalty-player-select');
              selects.forEach(sel => {
                google.script.run.withSuccessHandler(rData => {
                  if(rData.status === 'success') {
                    let html = '<option value="">Selecteer speler...</option>';
                    for(let i=1; i<rData.data.length; i++) html += '<option value="#' + rData.data[i][2] + ' ' + rData.data[i][0] + '">#' + rData.data[i][2] + ' ' + rData.data[i][0] + '</option>';
                    sel.innerHTML = html;
                  }
                }).doAction('Rosters', 'haalRosterOp', teamId);
              });
            }
          });
        });

        function updateClockDisplay() {
          const mins = Math.floor(AppState.clockSeconds / 60); const secs = AppState.clockSeconds % 60;
          const displayStr = mins.toString().padStart(2, '0') + ':' + secs.toString().padStart(2, '0');
          if(DOM.clock.main) DOM.clock.main.textContent = displayStr;
          if(DOM.clock.modal) DOM.clock.modal.textContent = displayStr;
        }
        function startClock() { if (!AppState.isRunning) { AppState.isRunning = true; if(DOM.clock.btnToggle) DOM.clock.btnToggle.innerHTML = '<span class="material-symbols-outlined">pause</span>'; AppState.clockInterval = setInterval(() => { if (AppState.clockSeconds > 0) { AppState.clockSeconds--; updateClockDisplay(); } else stopClock(); }, 1000); } }
        function stopClock() { AppState.isRunning = false; if(DOM.clock.btnToggle) DOM.clock.btnToggle.innerHTML = '<span class="material-symbols-outlined">play_arrow</span>'; clearInterval(AppState.clockInterval); }

        if(DOM.clock.btnToggle) DOM.clock.btnToggle.addEventListener('click', () => { if(AppState.isRunning) stopClock(); else startClock(); });
        if(DOM.clock.btnPlus) DOM.clock.btnPlus.addEventListener('click', () => { AppState.clockSeconds++; updateClockDisplay(); });
        if(DOM.clock.btnMinus) DOM.clock.btnMinus.addEventListener('click', () => { if(AppState.clockSeconds>0) { AppState.clockSeconds--; updateClockDisplay(); }});

        const periodSelect = document.getElementById('live-period-select');
        if (periodSelect) {
          periodSelect.addEventListener('change', (e) => {
            if(DOM.scoreboard.period) DOM.scoreboard.period.innerText = e.target.value;
            if(DOM.settings.inputMinutes) AppState.clockSeconds = parseInt(DOM.settings.inputMinutes.value) * 60; updateClockDisplay();
          });
        }

        function updateStatsUI() {
          const h = AppState.stats.HOME; const a = AppState.stats.AWAY;
          if(DOM.scoreboard.homeShots) DOM.scoreboard.homeShots.innerText = h.shots + " shots";
          if(DOM.scoreboard.awayShots) DOM.scoreboard.awayShots.innerText = a.shots + " shots";
          if(DOM.stats.shotsH) DOM.stats.shotsH.innerText = h.shots; if(DOM.stats.shotsA) DOM.stats.shotsA.innerText = a.shots;
          const totShots = h.shots + a.shots || 1;
          if(DOM.stats.barShotsH) DOM.stats.barShotsH.style.width = ((h.shots/totShots)*100) + '%'; if(DOM.stats.barShotsA) DOM.stats.barShotsA.style.width = ((a.shots/totShots)*100) + '%';
          if(DOM.stats.foH) DOM.stats.foH.innerText = h.faceoffs; if(DOM.stats.foA) DOM.stats.foA.innerText = a.faceoffs;
          const totFo = h.faceoffs + a.faceoffs || 1;
          if(DOM.stats.barFoH) DOM.stats.barFoH.style.width = ((h.faceoffs/totFo)*100) + '%'; if(DOM.stats.barFoA) DOM.stats.barFoA.style.width = ((a.faceoffs/totFo)*100) + '%';
          if(DOM.stats.goalsH) DOM.stats.goalsH.innerText = h.score; if(DOM.stats.goalsA) DOM.stats.goalsA.innerText = a.score;
          if(DOM.stats.penH) DOM.stats.penH.innerText = h.penalties; if(DOM.stats.penA) DOM.stats.penA.innerText = a.penalties;
        }

        const GASHooks = {
            logEvent: (eventType, details) => {
                google.script.run.doAction('Live', 'voegGeavanceerdEventToe', { wedstrijdId: AppState.dbMatchId || 'Custom', type: eventType, minuut: DOM.clock.main ? DOM.clock.main.textContent : "00:00", data: JSON.stringify(details) });
            }
        };

        function addEventToFeed(teamKey, title, subtitle, badgeText = '') {
            if (!DOM.feed.list) return;
            const bgClass = teamKey === 'HOME' ? 'bg-home-team' : 'bg-away-team';
            const txtClass = teamKey === 'HOME' ? 'text-home-team' : 'text-away-team';
            const tAfk = teamKey === 'HOME' ? AppState.homeTeam : AppState.awayTeam;
            const timeText = DOM.clock.main ? DOM.clock.main.textContent : "00:00";
            const periodText = DOM.scoreboard.period ? DOM.scoreboard.period.innerText : "1st";

            DOM.feed.list.insertAdjacentHTML('afterbegin', '<div class="flex items-center gap-4 bg-surface-container-high p-3 rounded-lg border border-outline-variant mt-2"><div class="w-12 h-12 rounded-full ' + bgClass + ' flex items-center justify-center"><span class="font-bold text-white">' + tAfk.substring(0,1) + '</span></div><div class="flex-1 flex flex-col"><span class="font-bold text-on-surface">' + title + '</span><span class="text-sm opacity-70 text-on-surface">' + subtitle + '</span><span class="text-xs opacity-50 text-on-surface">' + periodText + ' - ' + timeText + '</span></div><div class="' + txtClass + ' font-bold text-sm">' + badgeText + '</div></div>');
        }

        if(DOM.rink.container) {
          DOM.rink.container.addEventListener('click', (e) => {
              const rect = DOM.rink.container.getBoundingClientRect();
              const pctX = ((e.clientX - rect.left) / rect.width) * 100;
              const pctY = ((e.clientY - rect.top) / rect.height) * 100;
              const aanvallendTeam = pctX < 50 ? 'HOME' : 'AWAY';
              const verdedigendTeam = aanvallendTeam === 'HOME' ? 'AWAY' : 'HOME';

              const actieveGoalieSelect = document.getElementById(verdedigendTeam === 'HOME' ? 'active-goalie-home' : 'active-goalie-away');
              const actieveGoalie = actieveGoalieSelect ? actieveGoalieSelect.value : 'Onbekend';

              AppState.stats[aanvallendTeam].shots++;
              AppState.stats[verdedigendTeam].saves++;
              updateStatsUI();

              GASHooks.logEvent('SHOT', {
                  team: aanvallendTeam,
                  savedByTeam: verdedigendTeam,
                  goalie: actieveGoalie,
                  x: Math.round(pctX),
                  y: Math.round(pctY)
              });

              addEventToFeed(aanvallendTeam, 'Schot op Doel', 'Gestopt door: ' + actieveGoalie, 'SCHOT');

              const m = document.createElement('div'); m.className = 'absolute rounded-full rink-marker z-50'; m.style.width = '12px'; m.style.height = '12px'; m.style.backgroundColor = aanvallendTeam==='HOME'?AppState.homeColor:AppState.awayColor; m.style.left = (e.clientX - rect.left - 6) + 'px'; m.style.top = (e.clientY - rect.top - 6) + 'px';
              DOM.rink.container.appendChild(m); setTimeout(() => { if (DOM.rink.container.contains(m)) DOM.rink.container.removeChild(m); }, 1000);
          });
        }

        document.querySelectorAll('.faceoff-log-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const tk = e.target.getAttribute('data-team'); AppState.stats[tk].faceoffs++; updateStatsUI();
                addEventToFeed(tk, 'Face-off Gewonnen', (tk === 'HOME' ? AppState.homeTeam : AppState.awayTeam) + ' wint de puck', 'FO');
                GASHooks.logEvent('FACEOFF_WON', { team: tk }); if(DOM.modal.container) DOM.modal.container.classList.add('hidden'); startClock();
            });
        });

        document.querySelectorAll('.penalty-team-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.penalty-team-btn').forEach(b => { b.classList.remove('bg-home-team', 'bg-away-team', 'font-bold'); b.classList.add('bg-surface-variant', 'text-on-surface'); });
                const tk = e.target.getAttribute('data-team');
                e.target.classList.add(tk === 'HOME' ? 'bg-home-team' : 'bg-away-team', 'font-bold'); e.target.classList.remove('bg-surface-variant', 'text-on-surface');
                AppState.ui.selectedPenaltyTeam = tk;
            });
        });

        const logPenaltyBtn = document.getElementById('log-penalty-btn');
        if (logPenaltyBtn) {
            logPenaltyBtn.addEventListener('click', () => {
                const selects = document.querySelectorAll('.penalty-log-select');
                const player = selects[0].value || 'Onbekende Speler'; const type = selects[1].value || 'Onbekende Straf';
                const tk = AppState.ui.selectedPenaltyTeam; AppState.stats[tk].penalties++; updateStatsUI();
                addEventToFeed(tk, player, type + ' (2 min)', 'STRAF');
                GASHooks.logEvent('PENALTY', { team: tk, speler: player, type }); if(DOM.modal.container) DOM.modal.container.classList.add('hidden'); startClock();
            });
        }

        document.querySelectorAll('.goal-team-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.goal-team-btn').forEach(b => { b.classList.remove('bg-home-team', 'bg-away-team', 'font-bold'); b.classList.add('bg-surface-variant', 'text-on-surface'); });
                const tk = e.target.getAttribute('data-team');
                e.target.classList.add(tk === 'HOME' ? 'bg-home-team' : 'bg-away-team', 'font-bold'); e.target.classList.remove('bg-surface-variant', 'text-on-surface');
                AppState.ui.selectedGoalTeam = tk;
            });
        });

        const logGoalBtn = document.getElementById('log-goal-btn');
        if (logGoalBtn) {
            logGoalBtn.addEventListener('click', () => {
                const selects = document.querySelectorAll('.goal-log-select');
                const scorer = selects[0].value || 'Onbekende Speler'; const ast1 = selects[1].value; const ast2 = selects[2].value;
                let assistText = 'Geen assist';
                if (ast1 && ast1 !== 'None' && ast2 && ast2 !== 'None') assistText = 'Ast: ' + ast1 + ', ' + ast2; else if (ast1 && ast1 !== 'None') assistText = 'Ast: ' + ast1; else if (ast2 && ast2 !== 'None') assistText = 'Ast: ' + ast2;

                const tk = AppState.ui.selectedGoalTeam;

                AppState.stats[tk].score++;
                AppState.stats[tk].shots++;

                updateStatsUI();
                if (tk === 'HOME') { if(DOM.scoreboard.homeScore) DOM.scoreboard.homeScore.textContent = AppState.stats.HOME.score; } else { if(DOM.scoreboard.awayScore) DOM.scoreboard.awayScore.textContent = AppState.stats.AWAY.score; }
                addEventToFeed(tk, scorer, assistText, 'GOAL');

                const verdedigendTeam = tk === 'HOME' ? 'AWAY' : 'HOME';
                const actieveGoalieSelect = document.getElementById(verdedigendTeam === 'HOME' ? 'active-goalie-home' : 'active-goalie-away');
                const actieveGoalie = actieveGoalieSelect ? actieveGoalieSelect.value : 'Onbekend';

                GASHooks.logEvent('GOAL', { team: tk, speler: scorer, assistText, goalieTegen: actieveGoalie });

                if(DOM.modal.container) DOM.modal.container.classList.add('hidden'); startClock();
            });
        }

        if(DOM.modal.btnWhistle) DOM.modal.btnWhistle.addEventListener('click', () => { stopClock(); if(DOM.modal.container) DOM.modal.container.classList.remove('hidden'); });
        if(DOM.modal.btnClose) DOM.modal.btnClose.addEventListener('click', () => { if(DOM.modal.container) DOM.modal.container.classList.add('hidden'); });
        if(DOM.modal.btnResume) DOM.modal.btnResume.addEventListener('click', () => { if(DOM.modal.container) DOM.modal.container.classList.add('hidden'); });

        document.querySelectorAll('.modal-action-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const targetId = btn.getAttribute('data-target'); const targetDiv = document.getElementById(targetId);
                const isHidden = targetDiv.classList.contains('hidden');
                document.querySelectorAll('[id$="-options"]').forEach(div => div.classList.add('hidden'));
                if (isHidden && targetDiv) targetDiv.classList.remove('hidden');
            });
        });

        const btnTriggerFinalize = document.getElementById('btn-trigger-finalize');
        if(btnTriggerFinalize) btnTriggerFinalize.addEventListener('click', () => { stopClock(); const postTab = document.getElementById('nav-post-game'); if(postTab) postTab.click(); });

        if(DOM.postgame.btnFinalize) DOM.postgame.btnFinalize.addEventListener('click', () => {
            DOM.postgame.btnFinalize.disabled = true; DOM.postgame.btnFinalize.innerText = "Verzenden naar Database...";
            const payload = { wedstrijdId: AppState.dbMatchId || 'Handmatig', uitslag: AppState.stats.HOME.score + ' - ' + AppState.stats.AWAY.score, stats: AppState.stats, settings: {}, signoff: { scorer: DOM.postgame.scorer.value, ref: DOM.postgame.ref.value } };

            google.script.run.withSuccessHandler(function(res) {
                if(res.status === 'success') {
                    DOM.postgame.btnFinalize.innerText = "✅ Opgeslagen!";
                    alert(res.data);
                } else {
                    DOM.postgame.btnFinalize.innerText = "❌ Fout";
                    DOM.postgame.btnFinalize.disabled = false;
                    alert("Fout bij opslaan: " + res.message);
                }
            }).doAction('Live', 'finalizeWedstrijd', payload);
        });

        updateClockDisplay();
      }

      function haalGebruikersOp() {
        document.getElementById('usersTableBody').innerHTML = '<tr><td colspan="4">Laden...</td></tr>';
        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          let html = (!res.data || res.data.length <= 1) ? '<tr><td colspan="4">Geen gebruikers.</td></tr>' : '';

          for(let i = 1; i < res.data.length; i++) {
            let ruweFoto = res.data[i][15];
            let fotoUrl = (ruweFoto && ruweFoto.includes('http'))
              ? ruweFoto
              : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(res.data[i][1]) + '&background=1f1f1f&color=FF9F00&bold=true';

            let naamMetFoto = '<div style="display: flex; align-items: center; gap: 10px;"><img src="' + fotoUrl + '" alt="Avatar" style="width: 34px; height: 34px; border-radius: 50%; object-fit: cover; border: 2px solid #353534;"><span><strong>' + res.data[i][1] + '</strong></span></div>';

            let safeNaam = escapeJS(res.data[i][1]);
            let safeRol = escapeJS(res.data[i][3]);
            let safeFoto = escapeJS(fotoUrl);
            let safeMerk = escapeJS(res.data[i][11] || '');
            let safeModel = escapeJS(res.data[i][12] || '');
            let safeCurve = escapeJS(res.data[i][13] || '');
            let safeFlex = escapeJS(res.data[i][14] || '');

            html += '<tr onclick="openSpelerProfiel(\'' + safeNaam + '\', \'' + safeRol + '\', \'' + safeFoto + '\', \'' + safeMerk + '\', \'' + safeModel + '\', \'' + safeCurve + '\', \'' + safeFlex + '\')" style="cursor:pointer;" class="hover:bg-surface-container-highest transition-colors"><td>' + naamMetFoto + '</td><td>' + res.data[i][2] + '</td><td>' + res.data[i][3] + '</td><td><span class="badge">' + res.data[i][4] + '</span></td></tr>';
          }
          document.getElementById('usersTableBody').innerHTML = html;
        }).doAction('Users', 'haalAlleUsersOp', null);
      }

      function slaUserOp() {
        const btn = document.getElementById('btnOpslaanUser');
        const melding = document.getElementById('userMelding');

        const data = {
          naam: document.getElementById('usrNaam').value,
          email: document.getElementById('usrEmail').value,
          rol: document.getElementById('usrRol').value,
          fotoUrl: document.getElementById('usrFoto').value,
          geboortedatum: document.getElementById('usrGebDatum').value,
          lengte: document.getElementById('usrLengte').value,
          gewicht: document.getElementById('usrGewicht').value,
          niveau: document.getElementById('usrNiveau').value,
          voorkeursnummer: document.getElementById('usrNummer').value,
          hand: document.getElementById('usrHand').value,
          stickMerk: document.getElementById('usrStickMerk').value,
          stickModel: document.getElementById('usrStickModel').value,
          stickBlad: document.getElementById('usrStickBlad').value,
          stickFlex: document.getElementById('usrStickFlex').value
        };

        if(!data.naam || !data.email) {
          melding.style.color = "red"; melding.innerText = "Naam en E-mailadres zijn verplicht."; return;
        }
        if(!data.stickMerk || !data.stickModel) {
          melding.style.color = "red"; melding.innerText = "Stick Merk en Model zijn verplicht in te vullen!"; return;
        }

        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="vertical-align:middle; font-size:18px;">save</span> Profiel Aanmaken';
          if(res.status === 'success' && !res.data.includes('❌')) {
            melding.style.color = "green"; melding.innerText = res.data;
            document.querySelectorAll('.profile-section input, .admin-card input').forEach(inp => inp.value = '');
            setTimeout(() => melding.innerText = '', 3000);
            haalGebruikersOp();
          } else {
            melding.style.color = "red"; melding.innerText = res.data || res.message;
          }
        }).doAction('Users', 'voegUserToe', data);
      }

      // HIER DE NIEUWE GAST-REGISTRATIE FUNCTIE
      function slaRegistratieOp() {
        const btn = document.getElementById('btnOpslaanReg');
        const melding = document.getElementById('regMelding');

        const data = {
          naam: document.getElementById('regNaam').value,
          email: document.getElementById('regEmail').value,
          rol: 'Speler', // Geforceerd, gasten kunnen geen beheerder worden
          fotoUrl: '',
          geboortedatum: document.getElementById('regGebDatum').value,
          lengte: document.getElementById('regLengte').value,
          gewicht: document.getElementById('regGewicht').value,
          niveau: document.getElementById('regNiveau').value,
          voorkeursnummer: document.getElementById('regNummer').value,
          hand: document.getElementById('regHand').value,
          stickMerk: document.getElementById('regStickMerk').value,
          stickModel: document.getElementById('regStickModel').value,
          stickBlad: document.getElementById('regStickBlad').value,
          stickFlex: document.getElementById('regStickFlex').value
        };

        if(!data.naam || !data.email) {
          melding.style.color = "#ef4444"; melding.innerText = "Naam en E-mailadres zijn verplicht."; return;
        }

        btn.disabled = true; btn.innerText = "Bezig met aanmelden...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined">how_to_reg</span> Registratie Voltooien';
          if(res.status === 'success' && !res.data.includes('❌')) {
            melding.style.color = "#4ade80";
            melding.innerText = "Aanmelding geslaagd! Selecteer in het menu links 'Rol: Speler' om een team te joinen.";
            document.querySelectorAll('.reg-input').forEach(inp => inp.value = '');
          } else {
            melding.style.color = "#ef4444"; melding.innerText = res.data || res.message;
          }
        }).doAction('Users', 'voegUserToe', data);
      }

      function haalCompetitiesOp() {
        document.getElementById('compTableBody').innerHTML = '<tr><td colspan="4" class="col-center">Laden...</td></tr>';
        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          let html = (!res.data || res.data.length <= 1) ? '<tr><td colspan="4" class="col-center">Geen competities.</td></tr>' : '';
          for(let i = 1; i < res.data.length; i++) html += '<tr><td><strong>' + res.data[i][1] + '</strong></td><td>' + res.data[i][2] + '</td><td>' + res.data[i][3] + '</td><td><span class="status-actief">' + res.data[i][4] + '</span></td></tr>';
          document.getElementById('compTableBody').innerHTML = html;
        }).doAction('Competities', 'haalCompetitiesOp', null);
      }

      function slaCompetitieOp() {
        const btn = document.getElementById('btnOpslaan'); const melding = document.getElementById('compMelding');
        const data = { naam: document.getElementById('compNaam').value, seizoen: document.getElementById('compSeizoen').value, niveau: document.getElementById('compNiveau').value };
        if(!data.naam || !data.seizoen) { melding.style.color = "red"; melding.innerText = "Vul alles in."; return; }
        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="vertical-align:middle; font-size:18px;">add_circle</span> Competitie Aanmaken';
          if(res.status === 'success') { melding.style.color = "green"; melding.innerText = res.data; document.getElementById('compNaam').value = ''; document.getElementById('compSeizoen').value = ''; haalCompetitiesOp();
          } else { melding.style.color = "red"; melding.innerText = res.message; }
        }).doAction('Competities', 'voegCompetitieToe', data);
      }

      function initTeamsScherm() {
        google.script.run.withSuccessHandler(function(res) {
          const dropdown = document.getElementById('teamCompetitie'); dropdown.innerHTML = '<option value="">-- Selecteer Competitie --</option>';
          if(res.status === 'success') { for(let i = 1; i < res.data.length; i++) dropdown.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + ' (' + res.data[i][2] + ')</option>'; }
        }).doAction('Competities', 'haalCompetitiesOp', null); haalTeamsOp();
      }

      function haalTeamsOp() {
        document.getElementById('teamTableBody').innerHTML = '<tr><td colspan="5" class="col-center">Laden...</td></tr>';
        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          let html = (!res.data || res.data.length <= 1) ? '<tr><td colspan="5" class="col-center">Geen teams.</td></tr>' : '';
          for(let i = 1; i < res.data.length; i++) {
            let safeTeamId = escapeJS(res.data[i][0]);
            let safeTeamNaam = escapeJS(res.data[i][1]);

            html += '<tr onclick="openTeamProfiel(\'' + safeTeamId + '\', \'' + safeTeamNaam + '\')" style="cursor:pointer;" class="hover:bg-surface-container-highest transition-colors"><td><strong>' + res.data[i][1] + '</strong></td><td>' + (res.data[i][2] || '-') + '</td><td><span class="color-dot" style="background-color: ' + (res.data[i][3] || '#ccc') + ';"></span>' + (res.data[i][3] || '-') + '</td><td>' + (res.data[i][5] || '-') + '</td><td><span class="status-actief">' + res.data[i][6] + '</span></td></tr>';
          }
          document.getElementById('teamTableBody').innerHTML = html;
        }).doAction('Teams', 'haalTeamsOp', null);
      }

      function slaTeamOp() {
        const btn = document.getElementById('btnOpslaanTeam'); const melding = document.getElementById('teamMelding');
        const data = { naam: document.getElementById('teamNaam').value, competitieId: document.getElementById('teamCompetitie').value, afkorting: document.getElementById('teamAfkorting').value, kleur: document.getElementById('teamKleur').value, coach: document.getElementById('teamCoach').value };
        if(!data.naam || !data.competitieId) { melding.style.color = "red"; melding.innerText = "Vul naam en competitie in."; return; }
        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="vertical-align:middle; font-size:18px;">add_circle</span> Team Aanmaken';
          if(res.status === 'success') { melding.style.color = "green"; melding.innerText = res.data; document.getElementById('teamNaam').value = ''; document.getElementById('teamAfkorting').value = ''; haalTeamsOp();
          } else { melding.style.color = "red"; melding.innerText = res.message; }
        }).doAction('Teams', 'voegTeamToe', data);
      }

      function initRostersScherm() {
        google.script.run.withSuccessHandler(res => {
          const dropdown = document.getElementById('rosterSelectTeam'); dropdown.innerHTML = '<option value="">-- Selecteer een Team --</option>';
          if(res.status === 'success') { for(let i = 1; i < res.data.length; i++) dropdown.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + '</option>'; }
        }).doAction('Teams', 'haalTeamsOp', null);
        dashHaalUsersVoorRoster();
      }

      function dashHaalUsersVoorRoster() {
        google.script.run.withSuccessHandler(res => {
          const dropdownUser = document.getElementById('rosterSelectUser');
          if(!dropdownUser) return;
          dropdownUser.innerHTML = '<option value="">-- Selecteer een Speler --</option>';
          if(res.status === 'success') { for(let i = 1; i < res.data.length; i++) dropdownUser.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + ' (' + res.data[i][3] + ')</option>'; }
        }).doAction('Users', 'haalAlleUsersOp', null);
      }

      function haalSpecifiekRosterOp() {
        const teamId = document.getElementById('rosterSelectTeam').value;
        const addDiv = document.getElementById('addPlayerDiv'); const tbody = document.getElementById('rosterTableBody');
        if(!teamId) { addDiv.style.display = 'none'; tbody.innerHTML = '<tr><td colspan="4" class="col-center" style="color:var(--text-muted);">Selecteer eerst een team.</td></tr>'; return; }
        addDiv.style.display = 'block'; tbody.innerHTML = '<tr><td colspan="4" class="col-center">Laden... ⏳</td></tr>';
        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          let html = (res.data.length <= 1) ? '<tr><td colspan="4" class="col-center" style="color:var(--text-muted);">Geen spelers in deze selectie.</td></tr>' : '';
          for(let i = 1; i < res.data.length; i++) {
             let posKleur = res.data[i][1] === 'Goalie' ? '#ef4444' : (res.data[i][1] === 'Defense' ? '#3b82f6' : '#10b981');
             html += '<tr style="border-bottom:1px solid var(--border);"><td><strong>' + res.data[i][0] + '</strong></td><td><span style="color:' + posKleur + '; font-weight:900; font-size:0.75rem; text-transform:uppercase; background:rgba(255,255,255,0.05); padding:4px 8px; border-radius:4px; border:1px solid ' + posKleur + '33;">' + res.data[i][1] + '</span></td><td style="font-weight:900; font-size:1.1rem; color:var(--text-muted);">' + res.data[i][2] + '</td><td><span class="status-actief">' + res.data[i][3] + '</span></td></tr>';
          }
          tbody.innerHTML = html;
        }).doAction('Rosters', 'haalRosterOp', teamId);
      }

      function toggleRosterSpelerType() {
         const isNieuw = document.getElementById('rosterTypeToggle').checked;
         document.getElementById('divBestaandeUser').style.display = isNieuw ? 'none' : 'block';
         document.getElementById('divNieuweSpeler').style.display = isNieuw ? 'block' : 'none';
      }

      function slaRosterOp() {
        const btn = document.getElementById('btnOpslaanRoster');
        const melding = document.getElementById('rosterMelding');
        const isNieuw = document.getElementById('rosterTypeToggle').checked;

        const data = {
            teamId: document.getElementById('rosterSelectTeam').value,
            positie: document.getElementById('rosterPositie').value,
            rugnummer: document.getElementById('rosterRugnummer').value,
            isNieuw: isNieuw
        };

        if (isNieuw) {
            data.nieuweNaam = document.getElementById('rosterNieuweNaam').value;
            if(!data.nieuweNaam || !data.rugnummer) { melding.style.color = "#ef4444"; melding.innerText = "Vul naam en rugnummer in."; return; }
        } else {
            data.userId = document.getElementById('rosterSelectUser').value;
            if(!data.userId || !data.rugnummer) { melding.style.color = "#ef4444"; melding.innerText = "Kies een speler en vul rugnummer in."; return; }
        }

        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="vertical-align:middle; font-size:18px;">add_circle</span> Toevoegen';

          if(res.status === 'success' && !res.data.includes('❌')) {
              melding.style.color = "#4ade80"; melding.innerText = res.data;
              haalSpecifiekRosterOp();
              if(isNieuw) {
                  document.getElementById('rosterNieuweNaam').value = '';
                  document.getElementById('rosterTypeToggle').checked = false;
                  toggleRosterSpelerType();
                  dashHaalUsersVoorRoster();
              } else {
                  document.getElementById('rosterSelectUser').value = '';
              }
              document.getElementById('rosterRugnummer').value = '';
              setTimeout(() => melding.innerText = '', 3000);
          } else {
              melding.style.color = "#ef4444"; melding.innerText = res.data || res.message;
          }
        }).doAction('Rosters', 'voegSpelerToe', data);
      }

      function initWedstrijdenScherm() {
        google.script.run.withSuccessHandler(res => {
          const adminForm = document.getElementById('admin-match-form');
          if(adminForm) { adminForm.style.display = (res === true) ? 'block' : 'none'; }
        }).doAction('Wedstrijden', 'checkIsBeheerder', null);

        google.script.run.withSuccessHandler(res => {
          const dropdown = document.getElementById('wedstrijdCompetitie');
          if(dropdown) {
             dropdown.innerHTML = '<option value="">-- Selecteer Competitie --</option>';
             if(res.status === 'success') { for(let i = 1; i < res.data.length; i++) dropdown.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + '</option>'; }
          }
        }).doAction('Competities', 'haalCompetitiesOp', null);

        google.script.run.withSuccessHandler(res => { if(res.status === 'success') globaalTeamsData = res.data; }).doAction('Teams', 'haalTeamsOp', null);
        haalWedstrijdenOp();
      }

      function filterTeamsVoorWedstrijd() {
        const compId = document.getElementById('wedstrijdCompetitie').value; const thuisDrop = document.getElementById('wedstrijdThuis'); const uitDrop = document.getElementById('wedstrijdUit');
        thuisDrop.innerHTML = '<option value="">-- Kies Thuis Team --</option>'; uitDrop.innerHTML = '<option value="">-- Kies Uit Team --</option>';
        if(!compId) return;
        for(let i = 1; i < globaalTeamsData.length; i++) {
          if(globaalTeamsData[i][2] === compId) {
            thuisDrop.innerHTML += '<option value="' + globaalTeamsData[i][0] + '">' + globaalTeamsData[i][1] + '</option>';
            uitDrop.innerHTML += '<option value="' + globaalTeamsData[i][0] + '">' + globaalTeamsData[i][1] + '</option>';
          }
        }
      }

      function haalWedstrijdenOp() {
        const container = document.getElementById('wedstrijd-cards-container');
        if(!container) return;
        container.innerHTML = '<div style="text-align:center; padding:40px; color:var(--text-muted); font-size:1.2rem; font-weight:bold;">Wedstrijdschema laden... ⏳</div>';

        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;

          if (!res.data || res.data.length <= 1) {
             container.innerHTML = '<div style="text-align:center; padding:40px; color:var(--text-muted);">Er zijn nog geen wedstrijden ingepland.</div>';
             return;
          }

          let html = '';
          for(let i = 0; i < res.data.length - 1; i++) {
            let isGespeeld = res.data[i][5] === 'Gespeeld';
            let statusBadge = isGespeeld ? '<span class="status-actief">FINAL</span>' : '<span class="status-gepland">' + res.data[i][5] + '</span>';

            let safeWedstrijdId = escapeJS(res.data[i][0]);
            let safeThuis = escapeJS(res.data[i][3]);
            let safeUit = escapeJS(res.data[i][4]);

            let actieKnop = isGespeeld
              ? '<button class="btn" style="padding: 8px 20px; font-size: 0.85rem;" onclick="bekijkBoxscore(\'' + safeWedstrijdId + '\', \'' + safeThuis + '\', \'' + safeUit + '\')"><span class="material-symbols-outlined" style="vertical-align:middle; font-size:18px;">query_stats</span> Recap</button>'
              : '<span style="font-weight:900; font-size:1.8rem; color:var(--border);">VS</span>';

            let scoreVeld = isGespeeld
              ? '<div style="font-size:2.8rem; font-weight:900; color:white; font-variant-numeric:tabular-nums; text-shadow: 0 2px 15px rgba(255,159,0,0.4);">' + res.data[i][6] + '</div>'
              : actieKnop;

            let liveBtnHtml = !isGespeeld ? '<div style="text-align:center; margin-top:20px; padding-top:20px; border-top:1px solid var(--border);"><button class="btn" style="background:var(--surface-hover); color:white; border:1px solid var(--border); width:100%; font-size:0.85rem;" onclick="document.querySelector(\'.nav-item[onclick*=\\\'Live\\\']\').click()">🔴 Open in Live Tracker</button></div>' : '';

            html += '<div class="match-card"><div class="match-card-header"><div style="font-weight:900; color:var(--accent); text-transform:uppercase; letter-spacing:1px; font-size:0.85rem; display:flex; align-items:center; gap:6px;"><span class="material-symbols-outlined" style="font-size:18px;">calendar_month</span> ' + res.data[i][1] + ' <span style="color:var(--border);">|</span> <span class="material-symbols-outlined" style="font-size:18px;">schedule</span> ' + res.data[i][2] + '</div><div>' + statusBadge + '</div></div><div class="match-card-body"><div class="match-team text-right">' + res.data[i][3] + '</div><div class="match-center">' + scoreVeld + '</div><div class="match-team text-left">' + res.data[i][4] + '</div></div>' + liveBtnHtml + '</div>';
          }
          container.innerHTML = html;
        }).doAction('Wedstrijden', 'haalWedstrijdenOp', null);
      }

      function slaWedstrijdOp() {
        const btn = document.getElementById('btnOpslaanWedstrijd'); const melding = document.getElementById('wedstrijdMelding');
        const data = { competitieId: document.getElementById('wedstrijdCompetitie').value, datum: document.getElementById('wedstrijdDatum').value, tijd: document.getElementById('wedstrijdTijd').value, thuisTeam: document.getElementById('wedstrijdThuis').value, uitTeam: document.getElementById('wedstrijdUit').value };
        if(!data.competitieId || !data.datum || !data.tijd || !data.thuisTeam || !data.uitTeam || data.thuisTeam === data.uitTeam) { melding.style.color = "#ef4444"; melding.innerText = "Vul alle velden in (teams mogen niet gelijk zijn)."; return; }

        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerText = "Wedstrijd Inplannen";
          if(res.status === 'success' && !res.data.includes('❌')) {
              melding.style.color = "#4ade80"; melding.innerText = res.data;
              haalWedstrijdenOp();
          } else {
              melding.style.color = "#ef4444"; melding.innerText = res.data || res.message;
          }
        }).doAction('Wedstrijden', 'voegWedstrijdToe', data);
      }

      function initStandenScherm() {
        google.script.run.withSuccessHandler(res => {
          const dropdown = document.getElementById('standenCompetitieSelect');
          dropdown.innerHTML = '<option value="">-- Selecteer Competitie --</option>';
          if(res.status === 'success') {
            for(let i = 1; i < res.data.length; i++) {
              dropdown.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + '</option>';
            }
          }
        }).doAction('Competities', 'haalCompetitiesOp', null);
      }

      function haalSpecifiekeStandOp() {
        const compId = document.getElementById('standenCompetitieSelect').value;
        const container = document.getElementById('standenTabelContainer');
        const tbody = document.getElementById('standenTableBody');

        if(!compId) { container.style.display = 'none'; return; }

        container.style.display = 'block';
        tbody.innerHTML = '<tr><td colspan="9" class="col-center">Stand berekenen...</td></tr>';

        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          const klassement = res.data;

          if(klassement.length === 0) {
            tbody.innerHTML = '<tr><td colspan="9" class="col-center">Geen teams in deze competitie.</td></tr>';
            return;
          }

          let html = '';
          klassement.forEach((team, index) => {
            let rank = index + 1;
            let badgeClass = rank <= 3 ? 'rank-' + rank : '';
            let doelsaldo = team.gf - team.ga;
            let dsKleur = doelsaldo > 0 ? '#166534' : (doelsaldo < 0 ? '#991b1b' : '#475569');
            let kleur = team.kleur || '#ccc';
            let afkorting = team.afkorting || '';

            html += '<tr class="stand-row"><td><span class="rank-badge ' + badgeClass + '">' + rank + '</span> <span class="color-dot" style="background-color: ' + kleur + ';"></span> <strong>' + team.naam + '</strong> <span style="color:#94a3b8; font-size:0.8rem; margin-left:5px;">' + afkorting + '</span></td><td class="col-center">' + team.gp + '</td><td class="col-center">' + team.w + '</td><td class="col-center">' + team.t + '</td><td class="col-center">' + team.l + '</td><td class="col-center">' + team.gf + '</td><td class="col-center">' + team.ga + '</td><td class="col-center" style="color: ' + dsKleur + '; font-weight:bold;">' + (doelsaldo > 0 ? '+' : '') + doelsaldo + '</td><td class="col-center" style="font-size:1.1rem; font-weight:bold; color:#0f172a;">' + team.pts + '</td></tr>';
          });

          tbody.innerHTML = html;
        }).doAction('Standen', 'haalStandenOp', compId);
      }

      window.dashHuidigeStatsType = 'skaters';
      window.dashGeladenStats = { skaters: [], goalies: [] };

      function initDashboardScherm() {
        haalBerichtenOp();
        dashHaalWedstrijdenOp();

        google.script.run.withSuccessHandler(function(res) {
          const defaultHero = document.getElementById('dash-default-hero');
          const careerHero = document.getElementById('dash-career-hero');

          if(res && res.team && careerHero && defaultHero) {
             defaultHero.style.display = 'none';
             careerHero.style.display = 'block';

             let tKleur = res.team.kleur || '#3b82f6';
             document.getElementById('mc-bg').style.background = 'linear-gradient(135deg, var(--surface) 0%, ' + tKleur + '44 100%)';
             document.getElementById('mc-team').innerText = res.team.naam;
             document.getElementById('mc-team').style.color = tKleur;
             document.getElementById('mc-naam').innerText = res.user.naam;
             document.getElementById('mc-pos').innerText = res.pos + ' | #' + res.num;

             let fotoUrl = (res.user.foto && res.user.foto.includes('http')) ? res.user.foto : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(res.user.naam) + '&background=1f1f1f&color=FF9F00&bold=true&size=200';
             document.getElementById('mc-foto').src = fotoUrl;
             document.getElementById('mc-foto').style.borderColor = tKleur;

             const statsContainer = document.getElementById('mc-stats-container');
             if(res.pos === 'Goalie') {
                let sv = res.stats ? res.stats.saves : 0;
                let ga = res.stats ? res.stats.ga : 0;
                let svp = res.stats ? res.stats.svPct : 0;
                statsContainer.innerHTML = '<div class="mc-stat-box"><div class="mc-stat-val">' + sv + '</div><div class="mc-stat-lbl">Saves</div></div><div class="mc-stat-box"><div class="mc-stat-val">' + ga + '</div><div class="mc-stat-lbl">GA</div></div><div class="mc-stat-box" style="background:var(--accent); color:#0a0a0a;"><div class="mc-stat-val" style="color:#0a0a0a;">' + svp + '%</div><div class="mc-stat-lbl" style="color:#0a0a0a;">SV%</div></div>';
             } else {
                let g = res.stats ? res.stats.g : 0;
                let a = res.stats ? res.stats.a : 0;
                let pts = res.stats ? res.stats.pts : 0;
                statsContainer.innerHTML = '<div class="mc-stat-box"><div class="mc-stat-val">' + g + '</div><div class="mc-stat-lbl">Goals</div></div><div class="mc-stat-box"><div class="mc-stat-val">' + a + '</div><div class="mc-stat-lbl">Assists</div></div><div class="mc-stat-box" style="background:var(--accent); color:#0a0a0a;"><div class="mc-stat-val" style="color:#0a0a0a;">' + pts + '</div><div class="mc-stat-lbl" style="color:#0a0a0a;">Points</div></div>';
             }

             const achievementsContainer = document.getElementById('mc-achievements');
             if (achievementsContainer) {
                 if (res.achievements && res.achievements.length > 0) {
                     let achHtml = '';
                     res.achievements.forEach(ach => {
                         achHtml += `<div title="${ach.naam}: ${ach.desc}" style="background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); border-radius:4px; padding:4px 8px; font-size:1.2rem; cursor:help;">${ach.icon}</div>`;
                     });
                     achievementsContainer.innerHTML = achHtml;
                 } else {
                     achievementsContainer.innerHTML = '';
                 }
             }

             const nextGameDiv = document.getElementById('mc-next-game');
             if(res.nextGame) {
                let thuisUitBadge = res.nextGame.isThuis ? '<span style="background:rgba(59,130,246,0.2); color:#3b82f6; padding:2px 6px; border-radius:4px; font-size:0.7rem;">THUIS</span>' : '<span style="background:rgba(239,68,68,0.2); color:#ef4444; padding:2px 6px; border-radius:4px; font-size:0.7rem;">UIT</span>';
                nextGameDiv.innerHTML = '<div style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; font-weight:bold; margin-bottom:5px;">Volgende Wedstrijd</div><div style="font-size:1.1rem; font-weight:900; color:white; margin-bottom:5px;">VS ' + res.nextGame.tegenstander + ' ' + thuisUitBadge + '</div><div style="font-size:0.85rem; color:var(--accent); font-weight:bold;"><span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">calendar_month</span> ' + res.nextGame.datum + ' om ' + res.nextGame.tijd + '</div>';
             } else {
                nextGameDiv.innerHTML = '<div style="font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; font-weight:bold;">Volgende Wedstrijd</div><div style="color:white; font-weight:bold; margin-top:5px;">Geen wedstrijden gepland.</div>';
             }
          } else {
             if(defaultHero) defaultHero.style.display = 'flex';
          }
        }).doAction('Users', 'haalMijnCareerData', null);

        google.script.run.withSuccessHandler(function(res) {
          const joinWidget = document.getElementById('dash-widget-join');
          if(joinWidget) {
             if(res && res.status === 'success' && res.data && res.data.inTeam === true) {
                joinWidget.style.display = 'none';
             } else {
                joinWidget.style.display = 'flex';
             }
          }
        }).doAction('Users', 'checkMijnTeamStatus', null);

        google.script.run.withSuccessHandler(function(res) {
          if(res.status === 'success') {
            let options = '<option value="">-- Kies League --</option>';
            for(let i = 1; i < res.data.length; i++) {
              options += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + '</option>';
            }

            const stSelect = document.getElementById('dashStandenCompetitie');
            const statSelect = document.getElementById('dashStatsCompetitie');
            if(stSelect) stSelect.innerHTML = options;
            if(statSelect) statSelect.innerHTML = options;

            if(res.data.length > 1) {
              if(stSelect) { stSelect.value = res.data[1][0]; dashHaalStandenOp(); }
              if(statSelect) { statSelect.value = res.data[1][0]; dashHaalStatsOp(); }
            }
          }
        }).doAction('Competities', 'haalCompetitiesOp', null);
      }

      function dashHaalWedstrijdenOp() {
        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          let recentOfLive = [];
          let aankomend = [];

          res.data.forEach((w, i) => {
             if(i === 0) return;
             if(w[5] === 'Gepland') { aankomend.push(w); }
             else { recentOfLive.push(w); }
          });

          const recentContainer = document.getElementById('dash-recent-games');
          if(recentContainer) {
             let rHtml = '';
             recentOfLive.slice(-3).reverse().forEach(w => {
                let isLive = w[5] !== 'Gespeeld';
                let badge = isLive ? '<span class="live-indicator"><div class="live-dot"></div> LIVE</span>' : '<span style="color: var(--text-muted); font-size: 0.75rem; font-weight: 800; letter-spacing: 1px;">FINAL</span>';
                let score = w[6] !== '-' ? w[6] : '0 - 0';
                let scoreClass = isLive ? 'score-highlight' : '';

                rHtml += '<div class="game-row" style="cursor:pointer;" onclick="bekijkLiveMatch(\'' + escapeJS(w[0]) + '\', \'' + escapeJS(w[3]) + '\', \'' + escapeJS(w[4]) + '\')"><div>' + badge + '<span class="team-name">' + w[3] + ' vs ' + w[4] + '</span></div><div class="score-display ' + scoreClass + '">' + score + '</div></div>';
             });
             if(!rHtml) rHtml = '<p style="color:var(--text-muted); font-size:0.85rem;">Geen recente wedstrijden.</p>';
             recentContainer.innerHTML = rHtml;
          }

          const upcomingContainer = document.getElementById('dash-upcoming-games');
          if(upcomingContainer) {
             let uHtml = '';
             aankomend.slice(0, 3).forEach(w => {
                uHtml += '<div class="game-row"><div><div style="font-size: 0.85rem; color: var(--accent); font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">' + w[1] + ' ' + w[2] + '</div><span class="team-name">' + w[3] + ' vs ' + w[4] + '</span></div></div>';
             });
             if(!uHtml) uHtml = '<p style="color:var(--text-muted); font-size:0.85rem;">Geen aankomende wedstrijden.</p>';
             upcomingContainer.innerHTML = uHtml;
          }
        }).doAction('Wedstrijden', 'haalWedstrijdenOp', null);
      }

      function bekijkLiveMatch(wedstrijdId, thuisNaam, uitNaam) {
         if(window.liveMatchInterval) clearInterval(window.liveMatchInterval);

         const canvas = document.getElementById('app-canvas');
         canvas.innerHTML = '<div style="display:flex; justify-content:center; align-items:center; height:300px;"><p style="color:var(--text-muted); font-size:1.2rem; font-weight:bold;">Live Match Viewer laden... ⏳</p></div>';

         google.script.run.withSuccessHandler(function(html) {
            canvas.innerHTML = html;
            document.getElementById('lm-thuis-naam').innerText = thuisNaam;
            document.getElementById('lm-uit-naam').innerText = uitNaam;

            fetchLiveMatchData(wedstrijdId);
            window.liveMatchInterval = setInterval(() => fetchLiveMatchData(wedstrijdId), 5000);

         }).getViewHTML('MatchViewer');
      }

      function fetchLiveMatchData(wedstrijdId) {
         google.script.run.withSuccessHandler(function(res) {
            if(res.status === 'success') {
               const data = res.data;
               document.getElementById('lm-score-thuis').innerText = data.stats.HOME.score;
               document.getElementById('lm-score-uit').innerText = data.stats.AWAY.score;

               if(data.status === 'Afgelopen') {
                  document.getElementById('lm-status-badge').innerHTML = 'FINAL';
                  document.getElementById('lm-status-badge').className = 'badge';
                  if(window.liveMatchInterval) clearInterval(window.liveMatchInterval);
               } else {
                  document.getElementById('lm-status-badge').innerHTML = '<div class="live-dot"></div> LIVE';
                  document.getElementById('lm-status-badge').className = 'live-indicator';
               }

               document.getElementById('lm-shots-thuis').innerText = data.stats.HOME.shots;
               document.getElementById('lm-shots-uit').innerText = data.stats.AWAY.shots;
               let totShots = data.stats.HOME.shots + data.stats.AWAY.shots || 1;
               document.getElementById('lm-bar-shots-thuis').style.width = (data.stats.HOME.shots / totShots * 100) + '%';
               document.getElementById('lm-bar-shots-uit').style.width = (data.stats.AWAY.shots / totShots * 100) + '%';

               document.getElementById('lm-fo-thuis').innerText = data.stats.HOME.faceoffs;
               document.getElementById('lm-fo-uit').innerText = data.stats.AWAY.faceoffs;
               let totFo = data.stats.HOME.faceoffs + data.stats.AWAY.faceoffs || 1;
               document.getElementById('lm-bar-fo-thuis').style.width = (data.stats.HOME.faceoffs / totFo * 100) + '%';
               document.getElementById('lm-bar-fo-uit').style.width = (data.stats.AWAY.faceoffs / totFo * 100) + '%';

               document.getElementById('lm-pen-thuis').innerText = data.stats.HOME.penalties * 2;
               document.getElementById('lm-pen-uit').innerText = data.stats.AWAY.penalties * 2;
               let totPen = data.stats.HOME.penalties + data.stats.AWAY.penalties || 1;
               document.getElementById('lm-bar-pen-thuis').style.width = (data.stats.HOME.penalties / totPen * 100) + '%';
               document.getElementById('lm-bar-pen-uit').style.width = (data.stats.AWAY.penalties / totPen * 100) + '%';

               let evHtml = '';
               data.events.forEach(e => {
                  let badge = e.type === 'GOAL' ? '🥅 GOAL' : (e.type === 'PENALTY' ? '⏱️ PENALTY' : '• ' + e.type);
                  let teamKleur = e.payload.team === 'HOME' ? '#3b82f6' : '#ef4444';
                  let speler = e.payload.scorer || e.payload.player || 'Onbekend';
                  evHtml += '<div class="mv-event" style="border-left: 4px solid ' + teamKleur + '"><div class="mv-event-time">' + e.minuut + '</div><div class="mv-event-desc"><strong>' + badge + '</strong> - ' + speler + '</div></div>';
               });
               document.getElementById('lm-events').innerHTML = evHtml || '<p style="color:var(--text-muted); font-style:italic;">Nog geen acties gelogd.</p>';
            }
         }).doAction('Live', 'haalLiveMatchData', wedstrijdId);
      }

      function dashHaalStandenOp() {
        const compId = document.getElementById('dashStandenCompetitie').value;
        const tbody = document.getElementById('dashStandenTbody');
        if(!tbody || !compId) return;

        tbody.innerHTML = '<tr><td colspan="4" class="col-center">Laden... ⏳</td></tr>';
        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success' || res.data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="col-center" style="color:var(--text-muted);">Nog geen standen data.</td></tr>';
            return;
          }
          let html = '';
          res.data.slice(0, 5).forEach((team, index) => {
            html += '<tr><td><span class="rank-badge ' + (index < 3 ? 'rank-'+(index+1) : '') + '" style="width:20px; height:20px; line-height:20px; font-size:0.7rem; margin-right:5px;">' + (index+1) + '</span> <strong>' + team.naam + '</strong></td><td class="col-center">' + team.gp + '</td><td class="col-center" style="color:#4ade80;">' + (team.gf - team.ga > 0 ? '+' : '') + (team.gf - team.ga) + '</td><td class="col-center" style="font-weight:bold; color:var(--accent);">' + team.pts + '</td></tr>';
          });
          tbody.innerHTML = html;
        }).doAction('Standen', 'haalStandenOp', compId);
      }

      function dashHaalStatsOp() {
        const compId = document.getElementById('dashStatsCompetitie').value;
        const tbody = document.getElementById('dashStatsTbody');
        if(!tbody || !compId) return;

        tbody.innerHTML = '<tr><td colspan="4" class="col-center">Laden... ⏳</td></tr>';

        google.script.run.withSuccessHandler(function(res) {
          if(res.status === 'success') {
            window.dashGeladenStats = res.data;
            dashRenderStatsActief();
          }
        }).doAction('Statistieken', 'haalSpelerStatsOp', compId);
      }

      function dashZetStats(type, btnElement) {
        window.dashHuidigeStatsType = type;
        document.querySelectorAll('.dash-toggle-btn').forEach(b => b.classList.remove('active'));
        btnElement.classList.add('active');
        dashRenderStatsActief();
      }

      function dashRenderStatsActief() {
        const tbody = document.getElementById('dashStatsTbody');
        const thead = document.getElementById('dashStatsThead');
        if(!tbody || !thead) return;

        let html = '';
        if(window.dashHuidigeStatsType === 'skaters') {
          thead.innerHTML = '<tr><th>Speler</th><th class="col-center">G</th><th class="col-center">A</th><th class="col-center">PTS</th></tr>';
          const lijst = window.dashGeladenStats.skaters.slice(0, 5);
          if(lijst.length === 0) html = '<tr><td colspan="4" class="col-center" style="color:var(--text-muted);">Geen spelerstatistieken.</td></tr>';
          lijst.forEach(s => {
            html += '<tr><td><strong>' + s.naam + '</strong></td><td class="col-center">' + s.g + '</td><td class="col-center">' + s.a + '</td><td class="col-center" style="color:white; font-weight:bold;">' + s.pts + '</td></tr>';
          });
        } else {
          thead.innerHTML = '<tr><th>Goalie</th><th class="col-center">SV</th><th class="col-center">GA</th><th class="col-center">SV%</th></tr>';
          const lijst = window.dashGeladenStats.goalies.slice(0, 5);
          if(lijst.length === 0) html = '<tr><td colspan="4" class="col-center" style="color:var(--text-muted);">Geen keeperstatistieken.</td></tr>';
          lijst.forEach(g => {
            html += '<tr><td><strong>' + g.naam + '</strong></td><td class="col-center">' + g.saves + '</td><td class="col-center">' + g.ga + '</td><td class="col-center" style="color:white; font-weight:bold;">' + g.svPct + '%</td></tr>';
          });
        }
        tbody.innerHTML = html;
      }

      function haalBerichtenOp() {
        const container = document.getElementById('nieuwsFeedContainer');
        if(container) container.innerHTML = '<p>Berichten laden...</p>';

        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success' || !container) return;
          const data = res.data;

          let html = '';
          let aantalBerichten = 0;

          data.forEach(rij => {
            if(rij[0] !== 'ID' && rij[0] !== '') {
              aantalBerichten++;
              html += '<div class="bericht-kaart"><div class="bericht-header"><h4 class="bericht-titel">' + rij[2] + '</h4><span class="bericht-meta">📅 ' + rij[1] + ' &nbsp;|&nbsp; 👤 ' + rij[4] + '</span></div><div class="bericht-tekst">' + rij[3] + '</div></div>';
            }
          });

          if(aantalBerichten === 0) html = '<p style="color:var(--text-muted); font-style:italic;">Er zijn nog geen berichten geplaatst.</p>';
          container.innerHTML = html;
        }).doAction('Announcements', 'haalBerichtenOp', null);
      }

      function slaBerichtOp() {
        const btn = document.getElementById('btnOpslaanBericht');
        const melding = document.getElementById('annMelding');
        const data = {
          titel: document.getElementById('annTitel').value,
          auteur: document.getElementById('annAuteur').value,
          bericht: document.getElementById('annBericht').value
        };

        if(!data.titel || !data.bericht) {
          melding.style.color = "red"; melding.innerText = "Titel en bericht zijn verplicht."; return;
        }

        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerText = "Plaats op Dashboard";
          if(res.status === 'success') {
            melding.style.color = "green"; melding.innerText = res.data;
            document.getElementById('annTitel').value = ''; document.getElementById('annBericht').value = '';
            setTimeout(() => melding.innerText = '', 3000);
            haalBerichtenOp();
          } else {
            melding.style.color = "red"; melding.innerText = res.message;
          }
        }).doAction('Announcements', 'voegBerichtToe', data);
      }

      document.addEventListener('DOMContentLoaded', () => {
        // App forceert bij opstarten de Gast-rol
        wisselRol('gast');
      });

      function initAanvragenScherm() {
        google.script.run.withSuccessHandler(res => {
          const dropdown = document.getElementById('reqSelectUser'); dropdown.innerHTML = '<option value="">-- Kies Account --</option>';
          if(res.status === 'success') { for(let i = 1; i < res.data.length; i++) dropdown.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + '</option>'; }
        }).doAction('Users', 'haalAlleUsersOp', null);

        google.script.run.withSuccessHandler(res => {
          const dropdown = document.getElementById('reqSelectTeam'); dropdown.innerHTML = '<option value="">-- Kies Team --</option>';
          if(res.status === 'success') { for(let i = 1; i < res.data.length; i++) dropdown.innerHTML += '<option value="' + res.data[i][0] + '">' + res.data[i][1] + '</option>'; }
        }).doAction('Teams', 'haalTeamsOp', null);

        haalOpenAanvragenOp();
      }

      function haalOpenAanvragenOp() {
        const tbody = document.getElementById('aanvragenTableBody');
        tbody.innerHTML = '<tr><td colspan="5" class="col-center">Aanvragen laden... ⏳</td></tr>';

        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          const aanvragen = res.data;

          if(aanvragen.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="col-center" style="color:var(--text-muted); font-style:italic;">Geen openstaande aanvragen.</td></tr>';
            return;
          }

          let html = '';
          aanvragen.forEach(a => {
            html += '<tr style="border-bottom:1px solid var(--border);"><td>' + a.datum + '</td><td><strong>' + a.userName + '</strong></td><td>' + a.teamName + '</td><td>' + a.positie + ' (#' + a.rugnummer + ')</td><td><button class="btn" style="padding:6px; background:#10b981; color:white; margin-right:5px;" title="Goedkeuren" onclick="verwerkAanvraag(\'' + a.id + '\', \'Goedgekeurd\')"><span class="material-symbols-outlined" style="font-size:16px;">check</span></button><button class="btn" style="padding:6px; background:#ef4444; color:white;" title="Afwijzen" onclick="verwerkAanvraag(\'' + a.id + '\', \'Afgewezen\')"><span class="material-symbols-outlined" style="font-size:16px;">close</span></button></td></tr>';
          });
          tbody.innerHTML = html;
        }).doAction('Aanvragen', 'haalOpenAanvragenOp', null);
      }

      function slaAanvraagOp() {
        const btn = document.getElementById('btnOpslaanAanvraag');
        const melding = document.getElementById('reqMelding');
        const data = {
          userId: document.getElementById('reqSelectUser').value,
          teamId: document.getElementById('reqSelectTeam').value,
          positie: document.getElementById('reqPositie').value,
          rugnummer: document.getElementById('reqRugnummer').value
        };

        if(!data.userId || !data.teamId || !data.rugnummer) {
          melding.style.color = "#ef4444"; melding.innerText = "Vul alle velden in."; return;
        }

        btn.disabled = true; btn.innerText = "Bezig...";
        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerText = "Verzoek Indienen";
          if(res.status === 'success') {
            melding.style.color = "#4ade80"; melding.innerText = res.data;
            document.getElementById('reqRugnummer').value = '';
            setTimeout(() => melding.innerText = '', 3000);
            haalOpenAanvragenOp();
          } else {
            melding.style.color = "#ef4444"; melding.innerText = res.message;
          }
        }).doAction('Aanvragen', 'voegAanvraagToe', data);
      }

      function verwerkAanvraag(aanvraagId, actie) {
        if(!confirm('Weet je zeker dat je deze aanvraag wilt ' + actie.toLowerCase() + '?')) return;

        google.script.run.withSuccessHandler(function(res) {
          alert(res.data);
          haalOpenAanvragenOp();
        }).doAction('Aanvragen', 'verwerkAanvraag', { aanvraagId: aanvraagId, actie: actie });
      }

      window.loadedAppStats = null;

      function initStatistiekenScherm() {
        const tbody = document.getElementById('statsTableBody');
        const table = tbody.parentNode;

        if(!document.getElementById('stats-toggle-container')) {
           let toggleHTML = '<div id="stats-toggle-container" style="display:flex; gap:10px; margin-bottom: 20px; padding: 0 20px;"><button id="btn-show-skaters" class="btn" style="background:var(--accent); color:#131313; flex:1;">Topscorers</button><button id="btn-show-goalies" class="btn" style="background:var(--surface-hover); color:var(--text-muted); border:1px solid var(--border); flex:1;">Goalies</button></div>';
           table.insertAdjacentHTML('beforebegin', toggleHTML);
        }

        tbody.innerHTML = '<tr><td colspan="6" class="col-center">Leaderboards berekenen... ⏳</td></tr>';

        google.script.run.withSuccessHandler(function(res) {
          if(res.status !== 'success') return;
          window.loadedAppStats = res.data;

          document.getElementById('btn-show-skaters').addEventListener('click', function() {
             this.style.background = 'var(--accent)'; this.style.color = '#131313'; this.style.border = 'none';
             let otherBtn = document.getElementById('btn-show-goalies');
             otherBtn.style.background = 'var(--surface-hover)'; otherBtn.style.color = 'var(--text-muted)'; otherBtn.style.border = '1px solid var(--border)';
             renderSkaterStats();
          });

          document.getElementById('btn-show-goalies').addEventListener('click', function() {
             this.style.background = 'var(--accent)'; this.style.color = '#131313'; this.style.border = 'none';
             let otherBtn = document.getElementById('btn-show-skaters');
             otherBtn.style.background = 'var(--surface-hover)'; otherBtn.style.color = 'var(--text-muted)'; otherBtn.style.border = '1px solid var(--border)';
             renderGoalieStats();
          });

          renderSkaterStats();

        }).doAction('Statistieken', 'haalSpelerStatsOp', null);
      }

      function renderSkaterStats() {
         const thead = document.getElementById('statsTableBody').previousElementSibling;
         thead.innerHTML = '<tr><th>#</th><th>Speler</th><th class="col-center">G</th><th class="col-center">A</th><th class="col-center">PTS</th><th class="col-center">PIM</th></tr>';

         const tbody = document.getElementById('statsTableBody');
         if(window.loadedAppStats.skaters.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="col-center" style="color:var(--text-muted); font-style:italic;">Geen statistieken gevonden.</td></tr>'; return;
         }

         let html = '';
         window.loadedAppStats.skaters.forEach((s, i) => {
            let rank = i + 1;
            let badgeClass = rank <= 3 ? 'rank-' + rank : '';
            html += '<tr class="stand-row"><td class="col-center"><span class="rank-badge ' + badgeClass + '">' + rank + '</span></td><td><strong>' + s.naam + '</strong></td><td class="col-center">' + s.g + '</td><td class="col-center">' + s.a + '</td><td class="col-center" style="font-weight:bold; color:var(--accent);">' + s.pts + '</td><td class="col-center" style="color: #ef4444;">' + s.pim + '</td></tr>';
         });
         tbody.innerHTML = html;
      }

      function renderGoalieStats() {
         const thead = document.getElementById('statsTableBody').previousElementSibling;
         thead.innerHTML = '<tr><th>#</th><th>Doelman</th><th class="col-center">SV</th><th class="col-center">GA</th><th class="col-center">SA</th><th class="col-center">SV%</th></tr>';

         const tbody = document.getElementById('statsTableBody');
         if(window.loadedAppStats.goalies.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="col-center" style="color:var(--text-muted); font-style:italic;">Nog geen keeper-data vastgelegd.</td></tr>'; return;
         }

         let html = '';
         window.loadedAppStats.goalies.forEach((g, i) => {
            let rank = i + 1;
            let badgeClass = rank <= 3 ? 'rank-' + rank : '';
            html += '<tr class="stand-row"><td class="col-center"><span class="rank-badge ' + badgeClass + '">' + rank + '</span></td><td><strong>' + g.naam + '</strong></td><td class="col-center">' + g.saves + '</td><td class="col-center">' + g.ga + '</td><td class="col-center">' + g.shotsAgainst + '</td><td class="col-center" style="font-weight:bold; color:var(--accent);">' + g.svPct + '%</td></tr>';
         });
         tbody.innerHTML = html;
      }

      function bekijkBoxscore(wedstrijdId, thuisNaam, uitNaam) {
        const canvas = document.getElementById('app-canvas');
        canvas.innerHTML = '<div style="display:flex; justify-content:center; align-items:center; height:300px;"><p style="color:var(--text-muted); font-size:1.2rem; font-weight:bold;">Boxscore ophalen... ⏳</p></div>';

        google.script.run.withSuccessHandler(function(html) {
          canvas.innerHTML = html;
          document.getElementById('bs-team-thuis').innerText = thuisNaam;
          document.getElementById('bs-team-uit').innerText = uitNaam;

          google.script.run.withSuccessHandler(function(res) {
             if(res.status === 'success') {
                const b = res.data.verslag;
                if(!b) { alert("Data niet gevonden in archief."); return; }

                let uitslagParts = b.uitslag.split('-');
                document.getElementById('bs-score-thuis').innerText = uitslagParts[0] ? uitslagParts[0].trim() : '0';
                document.getElementById('bs-score-uit').innerText = uitslagParts[1] ? uitslagParts[1].trim() : '0';

                const sH = b.stats.HOME.shots || 0;
                const sA = b.stats.AWAY.shots || 0;
                document.getElementById('bs-shots-h').innerText = sH;
                document.getElementById('bs-shots-a').innerText = sA;

                let totShots = sH + sA || 1;
                document.getElementById('bs-bar-shots-h').style.width = ((sH / totShots) * 100) + '%';
                document.getElementById('bs-bar-shots-a').style.width = ((sA / totShots) * 100) + '%';

                const savesH = b.stats.HOME.saves || 0;
                const savesA = b.stats.AWAY.saves || 0;
                document.getElementById('bs-saves-h').innerText = savesH;
                document.getElementById('bs-saves-a').innerText = savesA;
                let totSaves = savesH + savesA || 1;
                document.getElementById('bs-bar-saves-h').style.width = ((savesH / totSaves) * 100) + '%';
                document.getElementById('bs-bar-saves-a').style.width = ((savesA / totSaves) * 100) + '%';

                const shotsAgainstH = b.stats.AWAY.shots || 0;
                const shotsAgainstA = b.stats.HOME.shots || 0;

                const svpH = shotsAgainstH > 0 ? ((savesH / shotsAgainstH) * 100).toFixed(1) + '%' : '-';
                const svpA = shotsAgainstA > 0 ? ((savesA / shotsAgainstA) * 100).toFixed(1) + '%' : '-';
                document.getElementById('bs-svp-h').innerText = svpH;
                document.getElementById('bs-svp-a').innerText = svpA;

                const foH = b.stats.HOME.faceoffs || 0;
                const foA = b.stats.AWAY.faceoffs || 0;
                document.getElementById('bs-fo-h').innerText = foH;
                document.getElementById('bs-fo-a').innerText = foA;
                let totFo = foH + foA || 1;
                document.getElementById('bs-bar-fo-h').style.width = ((foH / totFo) * 100) + '%';
                document.getElementById('bs-bar-fo-a').style.width = ((foA / totFo) * 100) + '%';

                const pimH = (b.stats.HOME.penalties || 0) * 2;
                const pimA = (b.stats.AWAY.penalties || 0) * 2;
                document.getElementById('bs-pim-h').innerText = pimH;
                document.getElementById('bs-pim-a').innerText = pimA;
                let totPim = pimH + pimA || 1;
                document.getElementById('bs-bar-pim-h').style.width = ((pimH / totPim) * 100) + '%';
                document.getElementById('bs-bar-pim-a').style.width = ((pimA / totPim) * 100) + '%';

                document.getElementById('bs-ref-scorer').innerText = b.signoff.scorer || 'Niet ingevuld';
                document.getElementById('bs-ref-hoofd').innerText = b.signoff.ref || 'Niet ingevuld';

                let evHtml = '';
                res.data.events.forEach(e => {
                  let isHome = e.payload.team === 'HOME';
                  let teamKleur = isHome ? '#3b82f6' : '#ef4444';
                  let badge = e.type === 'GOAL' ? '🥅 GOAL' : (e.type === 'PENALTY' ? '⏱️ PENALTY' : '• ' + e.type);
                  let speler = e.payload.scorer || e.payload.player || 'Onbekend';

                  let extraInfo = '';
                  if(e.type === 'SHOT' && e.payload.x) extraInfo = ' <span style="font-size:0.75rem; color:#888;">(Pos: X' + e.payload.x + ', Y' + e.payload.y + ')</span>';

                  evHtml += '<div class="bs-event" style="border-left: 4px solid ' + teamKleur + '"><div class="bs-event-time">' + e.minuut + '</div><div class="bs-event-desc"><strong>' + badge + '</strong> - ' + speler + extraInfo + '</div></div>';
                });

                document.getElementById('bs-events').innerHTML = evHtml || '<p style="color:var(--text-muted); font-style:italic;">Geen events gelogd voor deze wedstrijd.</p>';
                document.getElementById('boxscore-loader').style.display = 'none';
                document.getElementById('boxscore-content').style.display = 'block';
             }
          }).doAction('Verslagen', 'haalBoxscoreOp', wedstrijdId);

        }).getViewHTML('Boxscore');
      }

      function initLijnenScherm() {
        google.script.run.withSuccessHandler(res => {
          const dropdown = document.getElementById('lineTeamSelect');
          dropdown.innerHTML = '<option value="">-- Kies Team --</option>';
          if(res.status === 'success') {
            res.data.forEach((t, i) => { if(i>0) dropdown.innerHTML += '<option value="' + t[0] + '">' + t[1] + '</option>'; });
          }
        }).doAction('Teams', 'haalTeamsOp', null);

        google.script.run.withSuccessHandler(res => {
          if(res.status === 'success') { alleSpelersLijnen = res.data; }
        }).doAction('Users', 'haalAlleUsersOp', null);
      }

      function laadTeamLijnen() {
        const teamId = document.getElementById('lineTeamSelect').value;
        const editor = document.getElementById('lines-editor');
        if(!teamId) { editor.style.display = 'none'; return; }

        editor.style.display = 'flex';
        document.getElementById('lines-container').innerHTML = '<p style="color:var(--text-muted);">Formaties ophalen... ⏳</p>';

        lineState = { teamId: teamId, roster: [], inactive: [], leen: [], numLines: 3, posities: {} };

        google.script.run.withSuccessHandler(rData => {
          if(rData.status === 'success') {
            for(let i=1; i<rData.data.length; i++) {
              lineState.roster.push({ naam: rData.data[i][0], pos: rData.data[i][1], num: rData.data[i][2] });
            }
          }

          google.script.run.withSuccessHandler(saved => {
            if(saved) {
               lineState.numLines = saved.__numLines || 3;
               lineState.inactive = saved.__inactive || [];
               lineState.leen = saved.__leen || [];

               for(const k in saved) {
                  if(!k.startsWith('__')) { lineState.posities[k] = saved[k]; }
               }
            }
            renderLijnenUI();
          }).doAction('Lijnen', 'haalLijnenOp', teamId);

        }).doAction('Rosters', 'haalRosterOp', teamId);
      }

      function renderLijnenUI() {
         document.getElementById('lines-num-select').value = lineState.numLines;
         const activeContainer = document.getElementById('lines-active-list');
         const inactiveContainer = document.getElementById('lines-inactive-list');
         activeContainer.innerHTML = ''; inactiveContainer.innerHTML = '';

         let activeCount = 0;
         const allAvailable = [];

         lineState.roster.forEach(p => allAvailable.push({naam: p.naam, pos: p.pos, num: p.num, isLeen: false}));
         lineState.leen.forEach(p => allAvailable.push({naam: p.naam, pos: p.pos, num: p.num, isLeen: true}));

         allAvailable.forEach(speler => {
            const isInactive = lineState.inactive.includes(speler.naam);
            const posKleur = speler.pos === 'Goalie' ? '#ef4444' : (speler.pos === 'Defense' ? '#3b82f6' : '#10b981');
            const safeNaam = escapeJS(speler.naam);

            let html = '<div class="player-chip ' + (isInactive ? 'inactive' : '') + '" onclick="toggleLijnSpelerStatus(\'' + safeNaam + '\')">';
            html += '<div style="display:flex; align-items:center; gap:10px;"><span class="color-dot" style="background:' + posKleur + ';"></span>';
            html += '<strong>#' + speler.num + ' ' + speler.naam + '</strong></div>';
            if(speler.isLeen) html += '<span class="status-gepland" style="font-size:0.6rem;">LEEN</span>';
            html += '<span class="material-symbols-outlined" style="opacity:0.5;">' + (isInactive ? 'add_circle' : 'remove_circle') + '</span></div>';

            if(isInactive) { inactiveContainer.innerHTML += html; }
            else { activeContainer.innerHTML += html; activeCount++; }
         });

         document.getElementById('lines-active-count').innerText = activeCount + ' Spelers';
         if(activeCount === 0) activeContainer.innerHTML = '<p style="color:var(--text-muted); font-size:0.8rem;">Geen actieve spelers.</p>';
         if(inactiveContainer.innerHTML === '') inactiveContainer.innerHTML = '<p style="color:var(--text-muted); font-size:0.8rem;">Iedereen is actief.</p>';

         const loanSelect = document.getElementById('lines-loan-select');
         loanSelect.innerHTML = '<option value="">-- Kies Speler --</option>';
         alleSpelersLijnen.forEach((u, i) => {
            if(i > 0) {
               const naam = u[1];
               if(!allAvailable.find(p => p.naam === naam)) {
                  loanSelect.innerHTML += '<option value="' + escapeJS(naam) + '">#' + (u[10] || '-') + ' ' + naam + '</option>';
               }
            }
         });

         const linesContainer = document.getElementById('lines-container');
         let linesHtml = '';

         let activeOptions = '<option value="">-- Leeg --</option>';
         allAvailable.filter(p => !lineState.inactive.includes(p.naam)).forEach(p => {
             activeOptions += '<option value="' + escapeJS(p.naam) + '">#' + p.num + ' ' + p.naam + (p.isLeen ? ' [LEEN]' : '') + '</option>';
         });

         for(let i = 1; i <= lineState.numLines; i++) {
            linesHtml += '<div class="line-section"><h4 class="line-title">' + i + 'e Lijn</h4><div class="pos-grid">';
            linesHtml += '<div class="pos-item"><label>Left Wing (LW)</label><select class="roster-select" id="l' + i + '-lw" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
            linesHtml += '<div class="pos-item"><label>Center (C)</label><select class="roster-select" id="l' + i + '-c" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
            linesHtml += '<div class="pos-item"><label>Right Wing (RW)</label><select class="roster-select" id="l' + i + '-rw" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
            linesHtml += '<div class="pos-item"><label>Left Defense (LD)</label><select class="roster-select" id="l' + i + '-ld" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
            linesHtml += '<div class="pos-item"><label>Right Defense (RD)</label><select class="roster-select" id="l' + i + '-rd" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
            linesHtml += '</div></div>';
         }

         linesHtml += '<div class="line-section" style="border-left-color: #ef4444;"><h4 class="line-title">Goalies</h4><div class="pos-grid">';
         linesHtml += '<div class="pos-item"><label>Starter (G1)</label><select class="roster-select" id="g-1" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
         linesHtml += '<div class="pos-item"><label>Backup (G2)</label><select class="roster-select" id="g-2" onchange="updateLineState(this)">' + activeOptions + '</select></div>';
         linesHtml += '</div></div>';

         linesContainer.innerHTML = linesHtml;

         for(const [posId, spelerNaam] of Object.entries(lineState.posities)) {
            const selectElement = document.getElementById(posId);
            if (selectElement && spelerNaam) {
                let exists = Array.from(selectElement.options).some(opt => opt.value === spelerNaam);
                if(!exists) {
                   selectElement.innerHTML += '<option value="' + escapeJS(spelerNaam) + '">' + spelerNaam + ' (INACTIEF)</option>';
                }
                selectElement.value = spelerNaam;
            }
         }
      }

      function updateLineState(selectElement) {
         lineState.posities[selectElement.id] = selectElement.value;
      }

      function toggleLijnSpelerStatus(naam) {
         if(lineState.inactive.includes(naam)) {
            lineState.inactive = lineState.inactive.filter(n => n !== naam);
         } else {
            lineState.inactive.push(naam);
            for(const key in lineState.posities) {
               if(lineState.posities[key] === naam) { lineState.posities[key] = ''; }
            }
         }
         renderLijnenUI();
      }

      function addLoanPlayerLijnen() {
         const select = document.getElementById('lines-loan-select');
         const naam = select.value;
         if(!naam) return;

         const user = alleSpelersLijnen.find(u => u[1] === naam);
         if(user) {
            lineState.leen.push({ naam: naam, pos: 'Forward', num: user[10] || '-' });
            renderLijnenUI();
         }
      }

      function veranderAantalLijnen(num) {
         lineState.numLines = parseInt(num);
         renderLijnenUI();
      }

      function autoFillLijnen() {
         const allAvailable = [];
         lineState.roster.forEach(p => allAvailable.push({naam: p.naam, pos: p.pos, num: p.num, isLeen: false}));
         lineState.leen.forEach(p => allAvailable.push({naam: p.naam, pos: p.pos, num: p.num, isLeen: true}));

         const actieveSpelers = allAvailable.filter(p => !lineState.inactive.includes(p.naam));

         let forwards = actieveSpelers.filter(p => p.pos === 'Forward' || p.isLeen);
         let defense = actieveSpelers.filter(p => p.pos === 'Defense');
         let goalies = actieveSpelers.filter(p => p.pos === 'Goalie');

         lineState.posities = {};

         for(let i = 1; i <= lineState.numLines; i++) {
            if(forwards.length > 0) lineState.posities['l'+i+'-lw'] = forwards.shift().naam;
            if(forwards.length > 0) lineState.posities['l'+i+'-c'] = forwards.shift().naam;
            if(forwards.length > 0) lineState.posities['l'+i+'-rw'] = forwards.shift().naam;

            if(defense.length > 0) lineState.posities['l'+i+'-ld'] = defense.shift().naam;
            if(defense.length > 0) lineState.posities['l'+i+'-rd'] = defense.shift().naam;
         }

         if(goalies.length > 0) lineState.posities['g-1'] = goalies.shift().naam;
         if(goalies.length > 0) lineState.posities['g-2'] = goalies.shift().naam;

         renderLijnenUI();
      }

      function slaLijnenOp() {
        const btn = document.getElementById('btnOpslaanLijnen');
        const melding = document.getElementById('lijnenMelding');
        if(!lineState.teamId) return;

        btn.disabled = true; btn.innerText = "Opslaan...";

        let payloadLijnen = {};
        for(const k in lineState.posities) { payloadLijnen[k] = lineState.posities[k]; }

        payloadLijnen.__numLines = lineState.numLines;
        payloadLijnen.__inactive = lineState.inactive;
        payloadLijnen.__leen = lineState.leen;

        google.script.run.withSuccessHandler(function(res) {
          btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="vertical-align:middle; font-size:18px;">save</span> Opslaan';
          melding.style.color = "#10b981"; melding.innerText = res.data;
          setTimeout(() => melding.innerText = '', 3000);
        }).doAction('Lijnen', 'slaLijnenOp', { teamId: lineState.teamId, lijnen: payloadLijnen });
      }

      function wisselRol(rol) {
        const menuItems = document.querySelectorAll('.nav-item');
        const beheerHeader = document.getElementById('beheerder-menu-header');

        menuItems.forEach(item => {
          const itemRol = item.getAttribute('data-role');
          if (itemRol === 'all' || itemRol === rol) {
            item.style.display = 'flex';
          } else {
            item.style.display = 'none';
          }
        });

        if (beheerHeader) {
          beheerHeader.style.display = (rol === 'beheerder') ? 'block' : 'none';
        }

        const navAll = document.querySelector('.nav-item[data-role="all"]');
        if (navAll) navAll.click();
      }

      function toggleMobielMenu() {
        const sidebar = document.getElementById('sidebar');
        if (sidebar) sidebar.classList.toggle('open');
      }

      function sluitMobielMenu() {
        if (window.innerWidth <= 768) {
          const sidebar = document.getElementById('sidebar');
          if (sidebar) sidebar.classList.remove('open');
        }
      }

      function sluitProfiel() {
         const playerDetail = document.getElementById('view-player-detail');
         const teamDetail = document.getElementById('view-team-detail');
         const appCanvas = document.getElementById('app-canvas');

         if(playerDetail) playerDetail.style.display = 'none';
         if(teamDetail) teamDetail.style.display = 'none';
         if(appCanvas) appCanvas.style.display = 'block';
      }

      function openSpelerProfiel(naam, rol, fotoUrl, stickMerk, stickModel, stickCurve, stickFlex) {
         const appCanvas = document.getElementById('app-canvas');
         const teamDetail = document.getElementById('view-team-detail');
         const playerDetail = document.getElementById('view-player-detail');

         if(appCanvas) appCanvas.style.display = 'none';
         if(teamDetail) teamDetail.style.display = 'none';

         document.getElementById('detail-player-name').innerText = naam || 'Onbekend';
         document.getElementById('detail-player-role').innerText = rol || 'Speler';

         let finalFoto = (fotoUrl && fotoUrl.includes('http'))
           ? fotoUrl
           : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(naam) + '&background=1f1f1f&color=FF9F00&bold=true&size=200';

         document.getElementById('detail-player-img').src = finalFoto;

         document.getElementById('detail-stick-brand').innerText = stickMerk || 'Niet opgegeven';
         document.getElementById('detail-stick-model').innerText = stickModel || 'Niet opgegeven';
         document.getElementById('detail-stick-curve').innerText = stickCurve || 'Niet opgegeven';
         document.getElementById('detail-stick-flex').innerText = stickFlex || 'Niet opgegeven';

         document.getElementById('detail-player-stats-loader').style.display = 'block';
         document.getElementById('detail-player-stats-container').style.display = 'none';
         document.getElementById('detail-goalie-stats-container').style.display = 'none';

         google.script.run.withSuccessHandler(res => {
            document.getElementById('detail-player-stats-loader').style.display = 'none';
            if(res.status === 'success') {
               const st = res.data;
               let spelerStats = st.skaters.find(s => s.naam === naam);
               let goalieStats = st.goalies.find(g => g.naam === naam);

               if(spelerStats) {
                  document.getElementById('detail-player-stats-container').style.display = 'grid';
                  document.getElementById('dp-stat-g').innerText = spelerStats.g;
                  document.getElementById('dp-stat-a').innerText = spelerStats.a;
                  document.getElementById('dp-stat-pts').innerText = spelerStats.pts;
                  document.getElementById('dp-stat-pim').innerText = spelerStats.pim;
               } else if (goalieStats) {
                  document.getElementById('detail-goalie-stats-container').style.display = 'grid';
                  document.getElementById('dp-stat-sv').innerText = goalieStats.saves;
                  document.getElementById('dp-stat-ga').innerText = goalieStats.ga;
                  document.getElementById('dp-stat-svp').innerText = goalieStats.svPct + '%';
               } else {
                  document.getElementById('detail-player-stats-loader').style.display = 'block';
                  document.getElementById('detail-player-stats-loader').innerText = 'Geen wedstrijddata gevonden voor deze speler.';
               }
            }
         }).doAction('Statistieken', 'haalSpelerStatsOp', null);

         if(playerDetail) playerDetail.style.display = 'block';
      }

      function openTeamProfiel(teamId, teamNaam, teamKleur) {
         const appCanvas = document.getElementById('app-canvas');
         const playerDetail = document.getElementById('view-player-detail');
         const teamDetail = document.getElementById('view-team-detail');

         if(appCanvas) appCanvas.style.display = 'none';
         if(playerDetail) playerDetail.style.display = 'none';

         document.getElementById('detail-team-name').innerText = teamNaam || 'Onbekend Team';

         let tk = teamKleur && teamKleur !== 'null' ? teamKleur : '#1e3a8a';
         document.getElementById('dt-header-bg').style.background = 'linear-gradient(135deg, ' + tk + ' 0%, var(--primary-nav) 100%)';

         if(teamDetail) teamDetail.style.display = 'block';

         const rosterContainer = document.getElementById('detail-team-roster');
         rosterContainer.innerHTML = '<p style="color:var(--text-muted); font-style:italic; text-align:center; padding: 30px 0;">Spelers ophalen... ⏳</p>';

         google.script.run.withSuccessHandler(res => {
             if(res.status === 'success' && res.data.length > 1) {
                 let html = '<table style="width:100%; color:white; text-align:left; border-collapse: collapse; background:transparent; border:none; box-shadow:none;">';
                 html += '<tr><th style="padding:12px 10px; color:var(--text-muted); border-bottom:2px solid var(--border); background:transparent; font-size:0.8rem; text-transform:uppercase;">Naam</th><th style="padding:12px 10px; color:var(--text-muted); border-bottom:2px solid var(--border); background:transparent; font-size:0.8rem; text-transform:uppercase;">Positie</th><th style="padding:12px 10px; color:var(--text-muted); border-bottom:2px solid var(--border); background:transparent; font-size:0.8rem; text-transform:uppercase; text-align:center;">#</th></tr>';
                 for(let i=1; i<res.data.length; i++) {
                     let posKleur = res.data[i][1] === 'Goalie' ? '#ef4444' : (res.data[i][1] === 'Defense' ? '#3b82f6' : '#10b981');
                     html += '<tr style="border-bottom:1px solid var(--border); transition:0.2s;"><td style="padding:12px 10px; font-weight:bold; font-size:1.1rem; border:none;">' + res.data[i][0] + '</td><td style="padding:12px 10px; border:none;"><span style="color:' + posKleur + '; font-weight:900; font-size:0.8rem; text-transform:uppercase; background:rgba(255,255,255,0.05); padding:4px 8px; border-radius:4px; border:1px solid ' + posKleur + '33;">' + res.data[i][1] + '</span></td><td style="padding:12px 10px; border:none; text-align:center; font-weight:900; font-size:1.2rem; color:var(--text-muted);">' + res.data[i][2] + '</td></tr>';
                 }
                 html += '</table>';
                 rosterContainer.innerHTML = html;
             } else {
                 rosterContainer.innerHTML = '<p style="color:var(--text-muted); font-style:italic; text-align:center; padding: 30px 0;">Er zitten momenteel geen actieve spelers in deze selectie.</p>';
             }
         }).doAction('Rosters', 'haalRosterOp', teamId);
      }

    </script>
  </body>
</html>
